{
    "id": "page_product_:id",
    "type": "View",
    "variant": "surface",
    "flex": 1,
    "layout": {
        "type": "vertical",
        "spacing": 12,
        "padding": [12, 16, 16, 16]
    },
    "events": {
        "onLoad": "@onProductLoad",
        "onShow": "@onProductShow"
    },
    "children": [
        {
            "id": "product_card",
            "type": "View",
            "variant": "card",
            "flex": 1,
            "style": { "borderColor": "#2E3648", "borderWidth": 1 },
            "layout": { "type": "vertical", "spacing": 12, "padding": [24, 20, 24, 20] },
            "children": [
                { "id": "product_badge", "type": "Label", "variant": "badge", "text": "货号" },
                { "id": "product_name", "type": "Label", "variant": "title", "text": "商品名称" },
                { "id": "product_price", "type": "Label", "variant": "price", "text": "¥0" },
                { "id": "product_desc", "type": "Label", "variant": "subtitle", "text": "正品保障 · 7天无理由退换" },
                {
                    "id": "product_divider",
                    "type": "View",
                    "variant": "divider",
                    "size": [326, 1]
                },
                {
                    "id": "btn_add_cart",
                    "type": "Button",
                    "variant": "secondary",
                    "text": "加入购物袋",
                    "size": [326, 46],
                    "events": { "onClick": "@productAddToCart" },
                    "style": { "borderColor": "#2E3648", "borderWidth": 1 }
                },
                {
                    "id": "btn_buy_now",
                    "type": "Button",
                    "variant": "primary",
                    "text": "立即购买",
                    "size": [326, 46],
                    "events": { "onClick": "@productBuyNow" }
                }
            ]
        }
    ]
}
