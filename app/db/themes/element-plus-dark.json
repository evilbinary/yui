{
  "name": "element-plus-dark",
  "version": "1.0",
  "description": "Element Plus 暗色主题（模拟 Vue Element Plus Dark）",
  "styles": [
    { "selector": "View", "style": { "bgColor": "#0A0A0A" } },

    { "selector": "Label", "style": { "color": "#E5EAF3", "fontSize": 12 } },

    {
      "selector": "Button",
      "style": {
        "bgColor": "#1D1E1F",
        "color": "#CFD3DC",
        "borderRadius": 4,
        "fontSize": 12
      }
    },

    {
      "selector": "Input",
      "style": {
        "bgColor": "#141414",
        "color": "#CFD3DC",
        "fontSize": 12,
        "borderRadius": 4,
        "borderColor": "#4C4D4F",
        "focusBorderColor": "#409EFF"
      }
    },

    {
      "selector": "Text",
      "style": {
        "color": "#E5EAF3",
        "bgColor": "#141414",
        "fontSize": 13,
        "lineNumberBgColor": "#1D1E1F",
        "lineNumberColor": "#8D9095",
        "cursorColor": "#409EFF",
        "selectionColor": "#409EFF44",
        "keyword": "#79BBFF",
        "string": "#95D475",
        "number": "#EEBE77",
        "comment": "#8D9095",
        "punctuation": "#CFD3DC"
      }
    },

    {
      "selector": "Table",
      "style": {
        "color": "#CFD3DC",
        "bgColor": "#141414",
        "headerBgColor": "#1D1E1F",
        "headerColor": "#A3A6AD",
        "gridLineColor": "#363637",
        "rowAltBgColor": "#1A1A1A",
        "rowHoverColor": "#262727",
        "rowSelectedColor": "#18222C",
        "cellFocusColor": "#18222C",
        "scrollbarColor": "#6C6E72",
        "scrollbarTrackColor": "#141414CC"
      }
    },

    {
      "selector": "Treeview",
      "style": {
        "color": "#CFD3DC",
        "bgColor": "#1D1E1F",
        "fontSize": 13,
        "selectedBgColor": "#18222C",
        "hoverBgColor": "#262727",
        "scrollbarColor": "#6C6E72",
        "scrollbarTrackColor": "#1D1E1FCC"
      }
    },

    {
      "selector": "Pagination",
      "style": {
        "color": "#A3A6AD",
        "buttonBgColor": "#262727",
        "buttonHoverColor": "#363637"
      }
    },

    {
      "selector": "Sash",
      "style": {
        "bgColor": "#363637",
        "hoverBgColor": "#4C4D4F",
        "borderColor": "#4C4D4F",
        "dotColor": "#6C6E72",
        "hoverDotColor": "#A3A6AD",
        "accentColor": "#409EFFB3"
      }
    },

    {
      "selector": "Checkbox",
      "style": {
        "bgColor": "#141414",
        "borderColor": "#4C4D4F",
        "checkColor": "#409EFF"
      }
    },
    {
      "selector": "Checkbox.switch",
      "style": {
        "bgColor": "#2B2B2C",
        "borderColor": "#4C4D4F",
        "checkColor": "#409EFF"
      }
    },

    {
      "selector": "Menu",
      "style": {
        "bgColor": "#1D1E1F",
        "textColor": "#E5EAF3",
        "hoverColor": "#18222C",
        "disabledColor": "#6C6E72",
        "separatorColor": "#363637",
        "itemHeight": 34
      }
    },

    {
      "selector": "Dialog",
      "style": {
        "titleColor": "#E5EAF3",
        "textColor": "#CFD3DC",
        "bgColor": "#1D1E1F",
        "borderColor": "#4C4D4F",
        "buttonColor": "#262727",
        "buttonHoverColor": "#363637",
        "buttonTextColor": "#409EFF"
      }
    },

    {
      "selector": "View.tabBar",
      "style": {
        "bgColor": "#141414",
        "borderBottomWidth": 1,
        "borderBottomColor": "#363637"
      }
    },
    {
      "selector": "Label.tab",
      "style": {
        "color": "#CFD3DC",
        "fontSize": 12,
        "padding": [4, 16, 4, 16],
        "borderRadius": 0,
        "bgColor": "transparent"
      }
    },
    {
      "selector": "Label.tab.active",
      "style": {
        "color": "#409EFF",
        "bgColor": "transparent",
        "fontSize": 12,
        "padding": [4, 16, 4, 16],
        "borderRadius": 0
      }
    },
    {
      "selector": "Label.tabAdd",
      "style": {
        "color": "#8D9095",
        "fontSize": 14
      }
    },
    {
      "selector": "View.settingsCard",
      "style": {
        "bgColor": "#141414",
        "borderRadius": 8,
        "borderWidth": 1,
        "borderColor": "#363637"
      }
    },
    {
      "selector": "#preferencesDialogFrame",
      "style": {
        "bgColor": "#4C4D4F",
        "borderRadius": 9
      }
    },
    {
      "selector": "Label.navItem",
      "style": {
        "color": "#CFD3DC",
        "fontSize": 12,
        "padding": [8, 12, 8, 12],
        "borderRadius": 6,
        "bgColor": "transparent"
      }
    },
    {
      "selector": "Label.navItem.active",
      "style": {
        "color": "#409EFF",
        "fontSize": 12,
        "padding": [8, 12, 8, 12],
        "borderRadius": 6,
        "bgColor": "#18222C"
      }
    },
    {
      "selector": "Label.sectionTitle",
      "style": {
        "color": "#8D9095",
        "fontSize": 11,
        "fontWeight": "bold"
      }
    }
  ]
}
