{
  "id": "dbEditor",
  "text": "DB",
  "type": "View",
  "size": [900, 600],
  "js": ["./db.js"],
  "events": {
    "onLoad": "@onLoad"
  },
  "icon": "app/db/icon.png",
  "layout": { "type": "absolute" },
  "style": {
    "titleBarBgColor": "#1E1E2E",
    "color": "#CDD6F4",
    "bgColor": "#1E1E2E"
  },
  "children": [
        {
          "position": [0, 0],
