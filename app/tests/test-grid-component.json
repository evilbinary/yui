        {
          "id": "l6",
          "type": "Button",
          "text": "F",
          "style": { "bgColor": "#89dceb", "color": "#1e1e2e", "fontSize": 14, "borderRadius": 4 },
          "events": { "onClick": "@onCellClick" }
        },
        {
          "id": "l7",
          "type": "Button",
          "text": "G",
          "style": { "bgColor": "#89dceb", "color": "#1e1e2e", "fontSize": 14, "borderRadius": 4 },
          "events": { "onClick": "@onCellClick" }
        },
        {
          "id": "l8",
          "type": "Button",
          "text": "H",
          "style": { "bgColor": "#89dceb", "color": "#1e1e2e", "fontSize": 14, "borderRadius": 4 },
          "events": { "onClick": "@onCellClick" }
        }
      ]
    },
    {
      "id": "sectionC",
      "type": "Label",
      "text": "C. 增量更新（layout.columns / children）",
      "size": [528, 20],
      "style": {
        "color": "#f9e2af",
        "fontSize": 13
      }
    },
    {
      "id": "ctrlRow1",
      "type": "View",
      "size": [528, 40],
      "layout": {
        "type": "horizontal",
        "spacing": 8
      },
      "children": [
        {
          "id": "gridCol2Btn",
          "type": "Button",
          "text": "Grid 2列",
          "size": [100, 36],
          "style": { "bgColor": "#89b4fa", "color": "#1e1e2e", "fontSize": 12, "borderRadius": 4 },
          "events": { "onClick": "@setGridColumns2" }
        },
        {
          "id": "gridCol3Btn",
          "type": "Button",
          "text": "Grid 3列",
          "size": [100, 36],
          "style": { "bgColor": "#89b4fa", "color": "#1e1e2e", "fontSize": 12, "borderRadius": 4 },
          "events": { "onClick": "@setGridColumns3" }
        },
        {
          "id": "gridCol4Btn",
          "type": "Button",
          "text": "Grid 4列",
          "size": [100, 36],
          "style": { "bgColor": "#89b4fa", "color": "#1e1e2e", "fontSize": 12, "borderRadius": 4 },
          "events": { "onClick": "@setGridColumns4" }
        },
        {
          "id": "addCellBtn",
          "type": "Button",
          "text": "添加格子",
          "size": [100, 36],
          "style": { "bgColor": "#a6e3a1", "color": "#1e1e2e", "fontSize": 12, "borderRadius": 4 },
          "events": { "onClick": "@addGridCell" }
        },
        {
          "id": "removeCellBtn",
          "type": "Button",
          "text": "移除末格",
          "size": [100, 36],
          "style": { "bgColor": "#f38ba8", "color": "#1e1e2e", "fontSize": 12, "borderRadius": 4 },
          "events": { "onClick": "@removeGridCell" }
        }
