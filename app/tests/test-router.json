{
    "id": "router_app",
    "type": "View",
    "size": [700, 460],
    "text": "Router Test",
    "js": ["../lib/router.js", "test-router.js"],
    "style": {
        "bgColor": "#1E1E2E",
        "color": "#CDD6F4"
    },
    "layout": {
        "type": "vertical",
        "spacing": 6,
        "padding": [8, 8, 8, 8]
    },
    "events": {
        "onLoad": "@onAppLoad",
        "onShow": "@onAppShow"
    },
    "children": [
        {
            "id": "nav",
            "type": "View",
            "size": [684, 40],
            "style": {
                "bgColor": "#313244"
            },
            "layout": {
                "type": "horizontal",
                "spacing": 6,
                "padding": [4, 4, 4, 4]
            },
            "children": [
                { "id": "btn_home", "type": "Button", "text": "Home", "events": { "onClick": "@goHome" } },
                { "id": "btn_list", "type": "Button", "text": "List", "events": { "onClick": "@goList" } },
                { "id": "btn_detail", "type": "Button", "text": "Detail", "events": { "onClick": "@goDetail" } },
                { "id": "btn_dynamic", "type": "Button", "text": "Dynamic", "events": { "onClick": "@goDynamic" } },
                { "id": "btn_admin", "type": "Button", "text": "Admin", "events": { "onClick": "@goAdmin" } },
                { "id": "btn_login", "type": "Button", "text": "Login", "events": { "onClick": "@doLogin" } },
                { "id": "btn_replace", "type": "Button", "text": "Replace", "events": { "onClick": "@goReplaceList" } },
                { "id": "btn_back", "type": "Button", "text": "Back", "events": { "onClick": "@goBack" } }
            ]
        },
        {
            "id": "page_outlet",
            "type": "View",
            "flex": 1,
            "style": {
                "bgColor": "#181825"
            },
            "layout": {
                "type": "vertical"
            },
            "children": [
                {
                    "id": "home",
                    "type": "View",
                    "flex": 1,
                    "visible": true,
                    "style": {
                        "bgColor": "#45475A"
                    },
                    "events": {
                        "onLoad": "@onHomeLoad",
                        "onShow": "@onHomeShow",
                        "onHide": "@onHomeHide"
                    },
                    "children": [
                        {
                            "id": "home_label",
                            "type": "Label",
                            "text": "Home",
                            "style": { "color": "#CDD6F4", "fontSize": 20 }
                        }
                    ]
                },
                {
                    "id": "list",
                    "type": "View",
                    "flex": 1,
                    "visible": false,
                    "style": {
                        "bgColor": "#45475A"
                    },
                    "events": {
                        "onLoad": "@onListLoad",
                        "onShow": "@onListShow",
                        "onHide": "@onListHide"
                    },
                    "children": [
                        {
                            "id": "list_label",
                            "type": "Label",
                            "text": "List",
                            "style": { "color": "#CDD6F4", "fontSize": 20 }
                        }
                    ]
                },
                {
                    "id": "detail",
                    "type": "View",
                    "flex": 1,
                    "visible": false,
                    "style": {
                        "bgColor": "#45475A"
                    },
                    "events": {
                        "onLoad": "@onDetailLoad",
                        "onShow": "@onDetailShow",
                        "onHide": "@onDetailHide"
                    },
                    "children": [
                        {
                            "id": "detail_label",
                            "type": "Label",
                            "text": "Static Detail (id=)",
                            "style": { "color": "#CDD6F4", "fontSize": 20 }
                        }
                    ]
                }
            ]
        },
        {
            "id": "route_info",
            "type": "Label",
            "size": [684, 22],
            "text": "route:",
            "style": { "color": "#A6ADC8", "fontSize": 14 }
        },
        {
            "id": "log",
            "type": "Label",
            "size": [684, 100],
            "text": "log:",
            "style": { "color": "#BAC2DE", "fontSize": 12 }
        }
    ]
}
