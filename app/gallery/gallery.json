    {
      "id": "galleryInfoDialog",
      "type": "Dialog",
      "title": "Gallery Dialog",
      "message": "主题切换后 Dialog 样式也会更新。",
      "dialogType": "info",
      "modal": true,
      "size": [420, 220],
      "buttons": [{ "text": "OK", "default": true }]
    }
