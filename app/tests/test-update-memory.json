{
    "id": "updateMemTestApp",
    "type": "View",
    "size": [900, 760],
    "js": "test-update-memory.js",
    "style": {
        "bgColor": "#1e1e2e"
    },
    "layout": {
        "type": "vertical",
        "spacing": 10,
        "padding": [16, 16, 16, 16]
    },
    "children": [
        {
            "id": "title",
            "type": "Label",
            "text": "YUI.update 内存压力测试",
            "size": [0, 32],
            "style": {
                "color": "#cdd6f4",
                "fontSize": 20
            }
        },
        {
            "id": "statusLabel",
            "type": "Label",
            "text": "状态：就绪（请用任务管理器观察 playground 进程内存）",
            "size": [0, 40],
            "style": {
                "color": "#a6adc8",
                "fontSize": 12
            }
        },
        {
            "id": "statsLabel",
            "type": "Label",
            "text": "统计：轮次 0 | update 0 | 耗时 0ms",
