{
    "id": "shopping_app",
    "type": "View",
    "variant": "surface",
    "size": [390, 844],
    "text": "优物商城",
    "js": [
        "../lib/router.js",
        "../lib/theme.js",
        "app.js",
        "page/home.js",
        "page/category.js",
        "page/product.js",
        "page/cart.js",
        "page/login.js"
    ],
    "layout": {
        "type": "vertical",
        "spacing": 0,
        "padding": [0, 0, 0, 0]
    },
    "events": {
        "onLoad": "@onAppLoad",
        "onShow": "@onAppShow"
    },
    "children": [
        {
            "id": "header",
            "type": "View",
            "variant": "toolbar",
            "size": [390, 56],
            "style": { "borderColor": "#2E3648", "borderWidth": 1 },
            "layout": {
                "type": "horizontal",
                "spacing": 6,
                "padding": [10, 12, 10, 12]
            },
            "children": [
                {
                    "id": "btn_back",
                    "type": "Button",
                    "variant": "tertiary",
                    "text": "返回",
                    "size": [48, 36],
                    "events": { "onClick": "@goBack" },
                    "style": { "borderColor": "#2E3648", "borderWidth": 1 }
                },
                {
                    "id": "btn_logo",
                    "type": "Button",
                    "variant": "primary",
                    "text": "优物",
                    "flex": 1,
                    "size": [0, 36],
                    "events": { "onClick": "@goHome" }
                },
                {
                    "id": "btn_theme",
                    "type": "Button",
                    "variants": ["tertiary", "compact"],
                    "text": "暗",
                    "size": [36, 36],
                    "events": { "onClick": "@toggleTheme" }
                },
                {
                    "id": "btn_capture",
                    "type": "Button",
                    "variant": "secondary",
                    "text": "图",
                    "size": [36, 36],
                    "events": { "onClick": "@captureScreen" },
                    "style": { "borderColor": "#2E3648", "borderWidth": 1 }
                },
                {
                    "id": "btn_cart",
                    "type": "Button",
                    "variant": "secondary",
                    "text": "袋·0",
                    "size": [52, 36],
                    "events": { "onClick": "@goCart" },
                    "style": { "borderColor": "#2E3648", "borderWidth": 1 }
                },
                {
                    "id": "btn_login",
                    "type": "Button",
                    "variant": "primary",
                    "text": "登录",
                    "size": [48, 36],
                    "events": { "onClick": "@goLogin" }
                }
            ]
        },
        {
            "id": "page_outlet",
            "type": "View",
            "variant": "surface",
            "flex": 1,
            "layout": { "type": "vertical" },
            "children": [
                {
                    "id": "page_home",
                    "type": "View",
                    "variant": "surface",
                    "flex": 1,
                    "visible": false,
                    "scrollable": 1,
                    "layout": { "type": "vertical", "spacing": 12, "padding": [12, 16, 16, 16] },
                    "events": { "onLoad": "@onHomeLoad", "onShow": "@onHomeShow" },
                    "children": [
                        {
                            "id": "home_hero",
                            "type": "View",
                            "variant": "card",
                            "size": [358, 96],
                            "style": { "borderColor": "#2E3648", "borderWidth": 1 },
                            "layout": { "type": "vertical", "spacing": 6, "padding": [18, 18, 18, 18] },
                            "children": [
                                { "id": "home_title", "type": "Label", "variant": "title", "text": "发现精品好物" },
                                { "id": "home_subtitle", "type": "Label", "variant": "subtitle", "text": "精选数码、服饰与图书，品质生活从这里开始" }
                            ]
                        },
                        { "id": "home_cat_label", "type": "Label", "variant": "overline", "text": "商品分类" },
                        {
                            "id": "btn_cat_electronics",
                            "type": "Button",
                            "variant": "tone-a",
                            "text": "数码电器",
                            "size": [358, 44],
                            "events": { "onClick": "@homeGoElectronics" },
                            "style": { "borderColor": "#7C6CFF", "borderWidth": 1 }
                        },
                        {
                            "id": "btn_cat_fashion",
                            "type": "Button",
                            "variant": "tone-b",
                            "text": "时尚服饰",
                            "size": [358, 44],
                            "events": { "onClick": "@homeGoFashion" },
                            "style": { "borderColor": "#E879A9", "borderWidth": 1 }
                        },
                        {
                            "id": "btn_cat_books",
                            "type": "Button",
                            "variant": "tone-c",
                            "text": "图书文具",
                            "size": [358, 44],
                            "events": { "onClick": "@homeGoBooks" },
                            "style": { "borderColor": "#5B8DEF", "borderWidth": 1 }
                        },
                        { "id": "home_feat_label", "type": "Label", "variant": "overline", "text": "为你推荐" },
                        { "id": "home_feat_info", "type": "Label", "variant": "subtitle", "text": "本周热销精选" },
                        {
                            "id": "btn_feat_1",
                            "type": "Button",
                            "variant": "secondary",
                            "text": "推荐商品 1",
                            "size": [358, 48],
                            "events": { "onClick": "@homeFeat1" },
                            "style": { "borderColor": "#2E3648", "borderWidth": 1 }
                        },
                        {
                            "id": "btn_feat_2",
                            "type": "Button",
                            "variant": "secondary",
                            "text": "推荐商品 2",
                            "size": [358, 48],
                            "events": { "onClick": "@homeFeat2" },
                            "style": { "borderColor": "#2E3648", "borderWidth": 1 }
                        },
                        {
                            "id": "btn_feat_3",
                            "type": "Button",
                            "variant": "secondary",
                            "text": "推荐商品 3",
                            "size": [358, 48],
                            "events": { "onClick": "@homeFeat3" },
                            "style": { "borderColor": "#2E3648", "borderWidth": 1 }
                        },
                        {
                            "id": "btn_feat_4",
                            "type": "Button",
                            "variant": "secondary",
                            "text": "推荐商品 4",
                            "size": [358, 48],
                            "events": { "onClick": "@homeFeat4" },
                            "style": { "borderColor": "#2E3648", "borderWidth": 1 }
                        }
                    ]
                },
                {
                    "id": "page_category",
                    "type": "View",
                    "variant": "surface",
                    "flex": 1,
                    "visible": false,
                    "scrollable": 1,
                    "layout": { "type": "vertical", "spacing": 10, "padding": [12, 16, 16, 16] },
                    "events": { "onLoad": "@onCategoryLoad", "onShow": "@onCategoryShow" },
                    "children": [
                        {
                            "id": "category_header",
                            "type": "View",
                            "variant": "card",
                            "size": [358, 68],
                            "style": { "borderColor": "#2E3648", "borderWidth": 1 },
                            "layout": { "type": "vertical", "spacing": 4, "padding": [14, 16, 14, 16] },
                            "children": [
                                { "id": "category_title", "type": "Label", "variant": "heading", "text": "分类" },
                                { "id": "category_hint", "type": "Label", "variant": "subtitle", "text": "请选择商品" }
                            ]
                        },
                        {
                            "id": "btn_cat_item_1",
                            "type": "Button",
                            "variant": "secondary",
                            "text": "商品 1",
                            "size": [358, 52],
                            "events": { "onClick": "@categoryItem1" },
                            "style": { "borderColor": "#2E3648", "borderWidth": 1 }
                        },
                        {
                            "id": "btn_cat_item_2",
                            "type": "Button",
                            "variant": "secondary",
                            "text": "商品 2",
                            "size": [358, 52],
                            "events": { "onClick": "@categoryItem2" },
                            "style": { "borderColor": "#2E3648", "borderWidth": 1 }
                        },
                        {
                            "id": "btn_cat_item_3",
                            "type": "Button",
                            "variant": "secondary",
                            "text": "商品 3",
                            "size": [358, 52],
                            "events": { "onClick": "@categoryItem3" },
                            "style": { "borderColor": "#2E3648", "borderWidth": 1 }
                        }
                    ]
                },
                {
                    "id": "page_cart",
                    "type": "View",
                    "variant": "surface",
                    "flex": 1,
                    "visible": false,
                    "layout": { "type": "vertical", "spacing": 10, "padding": [12, 16, 16, 16] },
                    "events": { "onLoad": "@onCartLoad", "onShow": "@onCartShow" },
                    "children": [
                        {
                            "id": "cart_header",
                            "type": "View",
                            "variant": "card",
                            "size": [358, 64],
                            "style": { "borderColor": "#2E3648", "borderWidth": 1 },
                            "layout": { "type": "vertical", "spacing": 4, "padding": [14, 16, 14, 16] },
                            "children": [
                                { "id": "cart_title", "type": "Label", "variant": "heading", "text": "购物袋" },
                                { "id": "cart_user", "type": "Label", "variant": "subtitle", "text": "当前用户：-" }
                            ]
                        },
                        {
                            "id": "cart_items_card",
                            "type": "View",
                            "variant": "elevated",
                            "flex": 1,
                            "style": { "borderColor": "#2E3648", "borderWidth": 1 },
                            "layout": { "type": "vertical", "spacing": 8, "padding": [14, 16, 14, 16] },
                            "children": [
                                { "id": "cart_line_1", "type": "Label", "variant": "body", "text": "购物袋是空的" },
                                { "id": "cart_line_2", "type": "Label", "variant": "body", "text": "" },
                                { "id": "cart_line_3", "type": "Label", "variant": "body", "text": "" }
                            ]
                        },
                        {
                            "id": "cart_total_bar",
                            "type": "View",
                            "variant": "panel",
                            "size": [358, 48],
                            "style": { "borderColor": "#7C6CFF", "borderWidth": 1 },
                            "layout": { "type": "vertical", "padding": [12, 16, 12, 16] },
                            "children": [
                                { "id": "cart_total", "type": "Label", "variant": "price", "text": "合计  ¥0" }
                            ]
                        },
                        {
                            "id": "cart_actions",
                            "type": "View",
                            "size": [358, 44],
                            "layout": { "type": "horizontal", "spacing": 10 },
                            "children": [
                                {
                                    "id": "btn_cart_clear",
                                    "type": "Button",
                                    "variant": "danger",
                                    "text": "清空",
                                    "flex": 1,
                                    "size": [0, 42],
                                    "events": { "onClick": "@cartClear" },
                                    "style": { "borderColor": "#2E3648", "borderWidth": 1 }
                                },
                                {
                                    "id": "btn_cart_continue",
                                    "type": "Button",
                                    "variant": "primary",
                                    "text": "继续逛逛",
                                    "flex": 2,
                                    "size": [0, 42],
                                    "events": { "onClick": "@cartContinue" }
                                }
                            ]
                        }
                    ]
                },
                {
                    "id": "page_login",
                    "type": "View",
                    "variant": "surface",
                    "flex": 1,
                    "visible": false,
                    "layout": { "type": "vertical", "spacing": 0, "padding": [24, 16, 24, 16] },
                    "events": { "onLoad": "@onLoginLoad", "onShow": "@onLoginShow" },
                    "children": [
                        {
                            "id": "login_card",
                            "type": "View",
                            "variant": "card",
                            "size": [358, 340],
                            "style": { "borderColor": "#2E3648", "borderWidth": 1 },
                            "layout": { "type": "vertical", "spacing": 12, "padding": [28, 24, 28, 24] },
                            "children": [
                                { "id": "login_title", "type": "Label", "variant": "title", "text": "欢迎回来" },
                                { "id": "login_hint", "type": "Label", "variant": "subtitle", "text": "登录后即可查看购物袋并安全结算" },
                                { "id": "login_redirect", "type": "Label", "variant": "link", "text": "" },
                                {
                                    "id": "btn_login_user",
                                    "type": "Button",
                                    "variants": ["primary", "block"],
                                    "text": "普通用户登录（小明）",
                                    "size": [310, 46],
                                    "events": { "onClick": "@loginAsUser" }
                                },
                                {
                                    "id": "btn_login_admin",
                                    "type": "Button",
                                    "variant": "secondary",
                                    "text": "管理员登录（小红）",
                                    "size": [310, 46],
                                    "events": { "onClick": "@loginAsAdmin" },
                                    "style": { "borderColor": "#2E3648", "borderWidth": 1 }
                                },
                                {
                                    "id": "btn_login_cancel",
                                    "type": "Button",
                                    "variant": "tertiary",
                                    "text": "稍后再说",
                                    "size": [310, 42],
                                    "events": { "onClick": "@loginCancel" }
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "id": "status_bar",
            "type": "View",
            "variant": "toolbar",
            "size": [390, 24],
            "style": { "borderColor": "#2E3648", "borderWidth": 1 },
            "layout": { "type": "vertical", "padding": [4, 14, 4, 14] },
            "children": [
                { "id": "status_text", "type": "Label", "variant": "caption", "text": "首页" }
            ]
        }
    ]
}
