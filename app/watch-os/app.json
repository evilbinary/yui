{
    "id": "watch_os",
    "type": "View",
    "variant": "watch-bezel",
    "assets": "app/assets",
    "font": "Roboto-Regular.ttf",
    "fontFallback": "NotoColorEmoji.ttf",
    "size": [390, 390],
    "text": "YUI Watch",
    "js": [
        "../lib/router.js",
        "../lib/theme.js",
        "app.js"
    ],
    "layout": {
        "type": "vertical",
        "spacing": 0,
        "padding": [0, 0, 0, 0]
    },
    "events": {
        "onLoad": "@onWatchLoad",
        "onShow": "@onWatchShow"
    },
    "children": [
        {
            "id": "status_bar",
            "type": "View",
            "variant": "toolbar",
            "size": [390, 22],
            "layout": {
                "type": "horizontal",
                "spacing": 4,
                "padding": [2, 16, 2, 16],
                "align": "space-between"
            },
            "children": [
                {
                    "id": "btn_back",
                    "type": "Button",
                    "variants": ["tertiary", "compact"],
                    "text": "‹",
                    "size": [28, 18],
                    "visible": false,
                    "events": { "onClick": "@goWatchBack" }
                },
                {
                    "id": "status_time",
                    "type": "Label",
                    "variant": "status-time",
                    "text": "10:09",
                    "flex": 1
                },
                {
                    "id": "status_icons",
                    "type": "View",
                    "size": [96, 18],
                    "layout": { "type": "horizontal", "spacing": 2, "align": "center" },
                    "children": [
                        { "id": "status_signal", "type": "Label", "variant": "status-icon", "text": "📶" },
                        { "id": "status_battery_icon", "type": "Label", "variant": "status-icon", "text": "🔋" },
                        { "id": "status_battery", "type": "Label", "variant": "status-battery", "text": "85%" }
                    ]
                }
            ]
        },
        {
            "id": "page_outlet",
            "type": "View",
            "variant": "surface",
            "flex": 1,
            "layout": { "type": "vertical" }
        }
    ]
}
