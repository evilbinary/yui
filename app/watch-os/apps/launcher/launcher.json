{
    "id": "page_launcher",
    "title": "启动器",
    "icon": "🚀",
    "watchApp": { "id": "launcher", "path": "/launcher", "order": 1, "launcher": false, "system": true },
    "js": ["launcher.js"],
    "type": "View",
    "variant": "surface",
    "flex": 1,
    "scrollable": 0,
    "layout": { "type": "vertical", "spacing": 8, "padding": [10, 20, 16, 20], "align": "center" },
    "events": { "onLoad": "@onLauncherLoad", "onShow": "@onLauncherShow" },
    "children": [
        { "id": "launcher_title", "type": "Label", "variant": "overline", "text": "APPS", "size": [342, 12] },
        { "id": "launcher_count", "type": "Label", "variant": "caption", "text": "", "size": [342, 12] },
        {
            "id": "launcher_bubble",
            "type": "View",
            "size": [380, 380],
            "layout": { "type": "absolute" },
            "events": { "onTouch": "@onLauncherTouch" },
            "children": []
        },
        {
            "id": "launcher_grid",
            "type": "Grid",
            "visible": false,
            "width": 342,
            "height": 60,
            "layout": { "columns": 4, "spacing": 10 },
            "children": []
        }
    ]
}
