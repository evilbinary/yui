                  "scrollable": 1,
                  "indentWidth": 18,
                  "events": { "onSelect": "@onGallerySelect" },
                  "nodes": [
                    {
                      "text": "项目",
                      "expanded": true,
                      "children": [
                        { "text": "src", "expanded": true, "children": [
                          { "text": "main.c", "children": [] },
                          { "text": "theme.c", "children": [] }
                        ]},
                        { "text": "app", "expanded": false, "children": [
                          { "text": "gallery", "children": [] }
                        ]}
                      ]
                    },
                    {
                      "text": "文档",
                      "expanded": false,
                      "children": [
                        { "text": "README.md", "children": [] }
                      ]
                    }
                  ]
                },
                {
                  "type": "View",
                  "size": [580, 190],
                  "layout": { "type": "vertical", "spacing": 12 },
                  "children": [
                    {
                      "id": "galleryTabBar",
                      "type": "View",
                      "variant": "tabBar",
                      "size": [560, 36],
                      "layout": { "type": "horizontal", "spacing": 4, "padding": [4, 8, 4, 8], "align": "center" },
                      "children": [
                        { "id": "galleryTab1", "type": "Label", "variant": "tab active", "text": "Tab One" },
                        { "id": "galleryTab2", "type": "Label", "variant": "tab", "text": "Tab Two" },
                        { "id": "galleryTab3", "type": "Label", "variant": "tab", "text": "Tab Three" },
                        { "id": "galleryTabAdd", "type": "Label", "variant": "tabAdd", "text": "+" }
                      ]
                    },
                    {
                      "id": "galleryPanel",
                      "type": "View",
                      "variant": "panel",
                      "size": [560, 80],
                      "layout": { "type": "vertical", "padding": [12, 12, 12, 12] },
                      "children": [
                        { "type": "Label", "variant": "body", "text": "Panel / tabBar / nav 样式预览区" }
                      ]
                    },
                    {
                      "id": "galleryPager",
                      "type": "Pagination",
                      "mode": "simple",
                      "size": [280, 28],
                      "page": 2,
                      "pageSize": 20,
                      "total": 200,
                      "showTotal": true,
                      "events": { "onChange": "@onGalleryPagerChange" }
                    },
                    {
                      "type": "View",
                      "size": [560, 40],
                      "layout": { "type": "horizontal", "spacing": 10, "align": "center" },
                      "children": [
                        { "id": "galleryNav1", "type": "Label", "variant": "navItem", "text": "导航项" },
                        { "id": "galleryNav2", "type": "Label", "variant": "navItem active", "text": "选中项" }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
