                    "id": "clearButton",
                    "type": "Button",
                    "text": "C",
                    "style": {
                        "color": "#FFFFFF",
                        "bgColor": "#FF5252",
                        "fontSize": 24,
                        "borderRadius": 8
                    },
                    "size": [
                        80,
                        80
                    ],
                    "events": {
                        "onClick": "@clearDisplay"
                    }
                },
                {
                    "id": "backspaceButton",
                    "type": "Button",
                    "text": "回退",
                    "style": {
                        "color": "#FFFFFF",
                        "bgColor": "#FF5252",
                        "fontSize": 24,
                        "borderRadius": 8
                    },
                    "size": [
                        80,
                        80
                    ],
                    "events": {
                        "onClick": "@backspace"
                    }
                },
                {
                    "id": "percentButton",
