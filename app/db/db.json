                "events": {
                  "onChange": "@onSearchDb"
                }
              },
              {
                "id": "dbTree",
                "type": "Treeview",
                "size": [224, 470],
                "flex": 1,
                "scrollable": 1,
                "style": {
                  "color": "#CDD6F4",
                  "bgColor": "#181825",
                  "fontSize": 13
                },
                "events": {
                  "onSelect": "@onDbSelect",
                  "onExpand": "@onDbExpand"
                }
              }
            ]
          },
          {
            "id": "editorPanel",
            "type": "View",
            "size": [660, 534],
            "layout": {
              "type": "vertical",
              "spacing": 0
            },
            "style": {
              "bgColor": "#1E1E2E"
            },
            "children": [
              {
                "id": "sqlEditorContainer",
                "type": "View",
                "size": [660, 400],
                "layout": {
                  "type": "vertical",
                  "spacing": 0
                },
                "style": {
                  "bgColor": "#11111B"
                },
                "children": [
                  {
                    "id": "sqlToolbar",
                    "type": "View",
                    "size": [660, 32],
                    "layout": {
                      "type": "horizontal",
                      "spacing": 4,
                      "padding": [6, 12, 6, 12],
                      "align": "center"
                    },
                    "style": {
                      "bgColor": "#181825",
                      "borderBottomWidth": 1,
                      "borderBottomColor": "#313244"
                    },
                    "children": [
                      {
                        "id": "btnRun",
                        "type": "Button",
                        "size": [48, 24],
                        "icon": "app/assets/icons/run.svg",
                        "text": "运行",
                        "style": {
                          "color": "#A6E3A1",
                          "bgColor": "#313244",
                          "borderRadius": 4,
                          "fontSize": 11
                        },
                        "events": { "onClick": "@executeQuery" }
                      },
                      {
                        "id": "btnExplain",
                        "type": "Button",
                        "size": [28, 22],
                        "icon": "app/assets/icons/btnExplain.svg",
                        "style": {
                          "color": "#F9E2AF",
                          "bgColor": "transparent",
                          "fontSize": 12,
                          "borderRadius": 3
                        },
                        "events": { "onClick": "@onExplain" }
                      },
                      {
                        "id": "btnFormat",
                        "type": "Button",
                        "size": [28, 22],
                        "icon": "app/assets/icons/btnFormat.svg",
                        "style": {
                          "color": "#89B4FA",
                          "bgColor": "transparent",
                          "fontSize": 13,
                          "borderRadius": 3
                        },
                        "events": { "onClick": "@onFormat" }
                      },
                      {
                        "id": "btnSave",
                        "type": "Button",
                        "size": [28, 22],
                        "icon": "app/assets/icons/btnSave.svg",
                        "style": {
                          "color": "#A6ADC8",
                          "bgColor": "transparent",
                          "fontSize": 12,
                          "borderRadius": 3
                        },
                        "events": { "onClick": "@onSave" }
                      },
                      {
                        "id": "btnOpen",
                        "type": "Button",
                        "size": [28, 22],
                        "icon": "app/assets/icons/btnOpen.svg",
                        "style": {
                          "color": "#A6ADC8",
                          "bgColor": "transparent",
                          "fontSize": 12,
                          "borderRadius": 3
                        },
                        "events": { "onClick": "@onOpen" }
                      },
                      {
                        "id": "btnClear",
                        "type": "Button",
                        "size": [48, 24],
                        "text": "清空",
                        "style": {
                          "color": "#F38BA8",
                          "bgColor": "#313244",
                          "borderRadius": 4,
                          "fontSize": 11
                        },
                        "events": { "onClick": "@clearEditor" }
                      }
                    ]
                  },
                  {
                    "id": "sqlTabBar",
                    "type": "View",
                    "size": [660, 28],
                    "layout": {
                      "type": "horizontal",
                      "spacing": 0,
                      "padding": [6, 12, 6, 12],
                      "align": "center"
                    },
                    "style": {
                      "bgColor": "#11111B",
                      "borderBottomWidth": 1,
                      "borderBottomColor": "#313244"
                    },
                    "children": [
                      {
                        "id": "sqlTabs",
                        "type": "View",
                        "size": [600, 28],
                        "layout": {
                          "type": "horizontal",
                          "spacing": 0,
                          "align": "center"
                        },
                        "children": [
                          {
                            "id": "tab_0",
                            "type": "Label",
                            "text": "Query 1",
                            "style": {
                              "color": "#CDD6F4",
                              "bgColor": "#1E1E2E",
                              "fontSize": 11,
                              "padding": [4, 10, 4, 10],
                              "borderRadius": 4
                            },
                            "events": { "onClick": "@onTabClick" }
                          },
                          {
                            "id": "tab_1",
                            "type": "Label",
                            "text": "",
                            "visible": false,
                            "style": {
                              "color": "#6C7086",
                              "fontSize": 11,
                              "padding": [4, 10, 4, 10],
                              "borderRadius": 4
                            },
                            "events": { "onClick": "@onTabClick" }
                          },
                          {
                            "id": "tab_2",
                            "type": "Label",
                            "text": "",
                            "visible": false,
                            "style": {
                              "color": "#6C7086",
                              "fontSize": 11,
                              "padding": [4, 10, 4, 10],
                              "borderRadius": 4
                            },
                            "events": { "onClick": "@onTabClick" }
                          },
                          {
                            "id": "tab_3",
                            "type": "Label",
                            "text": "",
                            "visible": false,
                            "style": {
                              "color": "#6C7086",
                              "fontSize": 11,
                              "padding": [4, 10, 4, 10],
                              "borderRadius": 4
                            },
                            "events": { "onClick": "@onTabClick" }
                          },
                          {
                            "id": "tab_4",
                            "type": "Label",
                            "text": "",
                            "visible": false,
                            "style": {
                              "color": "#6C7086",
                              "fontSize": 11,
                              "padding": [4, 10, 4, 10],
                              "borderRadius": 4
                            },
                            "events": { "onClick": "@onTabClick" }
                          }
                        ]
                      },
                      {
                        "id": "newTabBtn",
                        "type": "Label",
                        "text": "+",
                        "style": {
                          "color": "#6C7086",
                          "fontSize": 14
                        },
                        "events": { "onClick": "@onNewTab" }
                      }
                    ]
                  },
                  {
                    "id": "sqlEditor",
                    "type": "Text",
                    "syntaxHighlight": "sql",
                    "text": "",
                    "size": [660, 340],
                    "flex": 1,
                    "multiline": true,
                    "editable": true,
                    "scrollable": 1,
                    "showLineNumbers": true,
                    "lineNumberWidth": 40,
                    "events": {
                      "onChange": "@onSqlChange"
                    },
                    "syntaxColors": {
                      "keyword": "#CBA6F7",
                      "string": "#A6E3A1",
                      "number": "#FAB387",
                      "comment": "#6C7086",
                      "punctuation": "#89DCEB"
                    },
                    "style": {
                      "color": "#CDD6F4",
                      "bgColor": "#11111B",
                      "fontSize": 13,
                      "padding": [12, 12, 12, 12],
                      "cursorColor": "#89B4FA"
                    }
                  }
                ]
              },
              {
                "id": "editorResultSash",
                "type": "Sash",
                "size": [660, 6],
                "target": "sqlEditorContainer",
                "minSize": 80,
                "style": {
                  "bgColor": "#313244"
                }
              },
              {
                "id": "resultContainer",
                "type": "View",
                "size": [660, 128],
                "layout": {
                  "type": "vertical",
                  "spacing": 0
                },
                "style": {
                  "bgColor": "#11111B"
                },
                "children": [
                  {
                    "id": "resultTabBar",
                    "type": "View",
                    "size": [660, 32],
                    "layout": {
                      "type": "horizontal",
                      "spacing": 12,
                      "padding": [8, 12, 8, 12],
                      "align": "center"
                    },
                    "style": {
                      "bgColor": "#181825",
                      "borderBottomWidth": 1,
                      "borderBottomColor": "#313244"
                    },
                    "children": [
                      {
                        "id": "resultTab",
                        "type": "Label",
                        "size": [80, 24],
                        "text": "查询结果",
                        "style": {
                          "color": "#CDD6F4",
                          "fontSize": 12
                        }
                      },
                      {
                        "id": "resultInfo",
                        "type": "Label",
                        "text": "(0 行)",
                        "style": {
                          "color": "#6C7086",
                          "fontSize": 11
                        }
                      },
                      {
                        "id": "resultPager",
                        "type": "Pagination",
                        "mode": "simple",
                        "size": [220, 28],
                        "page": 1,
                        "pageSize": 500,
                        "total": 0,
                        "hideOnSinglePage": false,
                        "showTotal": true,
                        "events": {
                          "onChange": "@onResultPageChange"
                        },
                        "style": {
                          "color": "#A6ADC8",
                          "bgColor": "transparent",
                          "fontSize": 11,
                          "disabledColor": "#45475A",
                          "buttonBgColor": "#313244",
                          "buttonHoverColor": "#45475A",
                          "borderRadius": 4,
                          "itemSize": 24
                        }
                      }
                    ]
                  },
                  {
                    "id": "resultTable",
                    "type": "Table",
                    "scrollable": 3,
                    "size": [660, 296],
                    "flex": 1,
                    "autoColumns": true,
                    "rowHeight": 28,
                    "headerHeight": 32,
                    "stripeRows": true,
                    "showGridLines": true,
                    "data": [],
                    "events": {
                      "onSelect": "@onResultRowClick"
                    },
                    "style": {
                      "color": "#CDD6F4",
                      "bgColor": "#11111B",
                      "fontSize": 13,
                      "headerBgColor": "#181825",
                      "headerColor": "#A6ADC8",
                      "rowAltBgColor": "#1a1a24",
                      "gridLineColor": "#313244"
                    }
                  }
                ]
              }
            ]
          }
      ]
    },
    {
      "id": "fileMenuPopup",
      "type": "Menu",
      "position": [0, 0],
      "size": [40, 175],
      "text": "文件",
      "fontSize": 12,
      "style": {
        "itemHeight": 29,
        "bgColor": "#1E1E2E",
        "textColor": "#CDD6F4",
        "hoverColor": "#45475A",
        "disabledColor": "#6C7086",
        "separatorColor": "#585B70"
      },
      "items": [
        { "text": "新建查询", "onClick": "@onNewTab" },
        { "text": "打开文件", "onClick": "@onOpen" },
        { "text": "保存文件", "onClick": "@onSave" },
        { "separator": true },
        { "text": "退出", "onClick": "onExit" }
      ],
      "events": {
            "onSelect": "@handleMenuClick"
        }
    },
    {
      "id": "dbMenuPopup",
      "type": "Menu",
      "position": [80, 0],
      "size": [40, 175],
      "text": "数据库",
      "fontSize": 12,
      "style": {
        "itemHeight": 29,
        "bgColor": "#1E1E2E",
        "textColor": "#CDD6F4",
        "hoverColor": "#45475A",
        "disabledColor": "#6C7086",
        "separatorColor": "#585B70"
      },
      "items": [
        { "text": "新建连接", "onClick": "onNewConnection" },
        { "text": "连接数据库", "onClick": "connectDb" },
        { "text": "断开连接", "onClick": "disconnectDb" },
        { "separator": true },
        { "text": "导入数据库", "onClick": "onImportDb" }
      ],
      "events": {
            "onSelect": "@handleMenuClick"
        }
    },
    {
      "id": "settingsMenuPopup",
      "type": "Menu",
      "position": [164, 0],
      "size": [40, 146],
      "text": "设置",
      "fontSize": 12,
      "style": {
        "itemHeight": 29,
        "bgColor": "#1E1E2E",
        "textColor": "#CDD6F4",
        "hoverColor": "#45475A",
        "disabledColor": "#6C7086",
        "separatorColor": "#585B70"
      },
      "items": [
        { "text": "偏好设置", "onClick": "onOpenSettings" },
        { "text": "主题设置", "onClick": "onThemeSettings" },
        { "separator": true },
        { "text": "关于", "onClick": "onAbout" }
      ],
      "events": {
            "onSelect": "@handleMenuClick"
        }
    },
    {
      "id": "statusBar",
      "type": "View",
      "position": [0, 570],
      "size": [900, 30],
      "layout": {
        "type": "horizontal",
        "spacing": 12,
        "padding": [8, 12, 8, 12],
        "align": "center"
      },
      "style": {
        "bgColor": "#181825",
        "borderTopWidth": 1,
        "borderTopColor": "#313244"
      },
      "children": [
        {
          "id": "statusIcon",
          "type": "Label",
          "size": [20, 20],
          "text": "●",
          "style": {
            "color": "#F38BA8",
            "fontSize": 10
          }
        },
        {
          "id": "statusText",
          "type": "Label",
          "text": "未连接",
          "size": [300, 20],
          "textAlign": "left",
          "style": {
            "color": "#CDD6F4",
            "fontSize": 11,
            "fontWeight": "bold"
          }
        }
      ]
    },
    {
      "id": "aboutDialog",
      "type": "Dialog",
      "title": "关于 YUI",
      "message": "YUI - Ya Ya User Interface\n\n一款面向 AI 应用的轻量级 GUI 框架，由 evilbinary 开发，使用 C 语言构建，通过 JSON 描述界面。\n\n主要特性：\n• 轻量高性能，支持脏矩形渲染\n• 声明式 JSON 配置 UI\n• 跨平台（Windows / macOS / Linux）\n• 丰富组件、动画系统、主题切换\n• 支持 QuickJS / mquickjs / Mario 引擎\n\n许可证：LGPL-2.1\n项目地址：github.com/evilbinary/YUI\n\nYUI DB Editor v0.1",
      "dialogType": "info",
      "modal": true,
      "fontSize": 12,
      "size": [360, 240],
      "buttons": [
        { "text": "确定", "default": true, 
          "style": {
            "bgColor": "#313244",
            "hoverColor": "#45475A",
            "textColor": "#F38BA8",
            "width": 72,
            "height": 28
          }}
      ],
      "style": {
        "titleColor": "#89B4FA",
        "textColor": "#CDD6F4",
        "bgColor": "#1E1E2E",
        "borderColor": "#45475A",
        "buttonColor": "#45475A",
        "buttonHoverColor": "#585B70",
        "buttonTextColor": "#CDD6F4"
      }
    },
    {
      "id": "fileDialogOverlay",
      "type": "View",
      "visible": false,
      "position": [0, 0],
      "size": [900, 600],
      "style": { "bgColor": "#00000066" },
      "layout": { "type": "absolute" },
      "children": [
        {
          "id": "fileDialogPanel",
          "type": "View",
          "position": [120, 60],
          "size": [660, 480],
          "layout": { "type": "vertical", "spacing": 0, "padding": [0, 0, 0, 0] },
          "style": { "bgColor": "#1E1E2E", "borderRadius": 8 },
          "children": [
            {
              "id": "fileDialogTitleBar",
              "type": "View",
              "size": [660, 36],
              "layout": { "type": "horizontal", "align": "center", "padding": [0, 16, 0, 16] },
              "style": { "bgColor": "#181825", "borderBottomWidth": 1, "borderBottomColor": "#313244" },
              "children": [
                {
                  "id": "fileDialogTitle",
                  "type": "Label",
                  "text": "打开文件",
                  "style": { "color": "#CDD6F4", "fontSize": 13, "fontWeight": "bold" }
                }
              ]
            },
            {
              "id": "fileDialogNav",
              "type": "View",
              "size": [660, 36],
              "layout": { "type": "horizontal", "spacing": 6, "padding": [6, 12, 6, 12], "align": "center" },
              "style": { "bgColor": "#11111B", "borderBottomWidth": 1, "borderBottomColor": "#313244" },
              "children": [
                {
                  "id": "fileDialogUpBtn",
                  "type": "Button",
                  "size": [32, 24],
                  "text": "..",
                  "style": { "color": "#89B4FA", "bgColor": "#313244", "borderRadius": 3, "fontSize": 13 },
                  "events": { "onClick": "@onFileBrowserUp" }
                },
                {
                  "id": "fileDialogPath",
                  "type": "Label",
                  "size": [580, 24],
                  "text": "./",
                  "style": { "color": "#A6ADC8", "fontSize": 11 }
                }
              ]
            },
            {
              "id": "fileDialogList",
              "type": "Treeview",
              "size": [660, 320],
              "scrollable": 1,
              "style": { "color": "#CDD6F4", "bgColor": "#1E1E2E", "fontSize": 12 },
              "events": { "onSelect": "@onFileBrowserSelect" }
            },
            {
              "id": "fileDialogInputRow",
              "type": "View",
              "size": [660, 36],
              "layout": { "type": "horizontal", "spacing": 6, "padding": [6, 12, 6, 12], "align": "center" },
              "style": { "bgColor": "#11111B", "borderTopWidth": 1, "borderTopColor": "#313244" },
              "children": [
                {
                  "id": "fileDialogInputLabel",
                  "type": "Label",
                  "text": "文件名:",
                  "style": { "color": "#6C7086", "fontSize": 11 }
                },
                {
                  "id": "fileDialogInput",
                  "type": "Input",
                  "size": [520, 24],
                  "text": "",
                  "placeholder": "输入文件名...",
                  "style": { "color": "#CDD6F4", "bgColor": "#1E1E2E", "fontSize": 11, "padding": [4, 8, 4, 8] }
                }
              ]
            },
            {
              "id": "fileDialogButtons",
              "type": "View",
              "size": [660, 44],
              "layout": { "type": "horizontal", "spacing": 10, "padding": [8, 16, 8, 16] },
              "style": { "bgColor": "#181825", "borderTopWidth": 1, "borderTopColor": "#313244" },
              "children": [
                {
                  "id": "fileDialogOkBtn",
                  "type": "Button",
                  "size": [72, 28],
                  "text": "确定",
                  "style": { "color": "#A6E3A1", "bgColor": "#313244", "borderRadius": 4, "fontSize": 12 },
                  "events": { "onClick": "@onFileBrowserOk" }
                },
                {
                  "id": "fileDialogCancelBtn",
                  "type": "Button",
                  "size": [72, 28],
                  "text": "取消",
                  "style": { "color": "#F38BA8", "bgColor": "#313244", "borderRadius": 4, "fontSize": 12 },
                  "events": { "onClick": "@onFileBrowserCancel" }
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "events": {
    "onLoad": "@onLoad"
  }
}
