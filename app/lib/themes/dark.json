{
  "name": "dark",
  "version": "1.0",
  "description": "通用暗色主题 - 组件类型 + 复合选择器 Type.modifier",
  "styles": [
    {
      "selector": "View",
      "style": { "bgColor": "#0A0D12" }
    },
    {
      "selector": "Label",
      "style": { "color": "#F2F4F8", "fontSize": 14 }
    },
    {
      "selector": "Button",
      "style": {
        "bgColor": "#1A2030",
        "color": "#F2F4F8",
        "fontSize": 14,
        "borderRadius": 12
      }
    },
    {
      "selector": "Input",
      "style": {
        "bgColor": "#1A2030",
        "color": "#F2F4F8",
        "fontSize": 14,
        "borderRadius": 10
      }
    },
    {
      "selector": "Image",
      "style": { "bgColor": "#12161E", "borderRadius": 8 }
    },
    {
      "selector": "View.surface",
      "style": { "bgColor": "#0A0D12" }
    },
    {
      "selector": "View.elevated",
      "style": { "bgColor": "#12161E", "borderRadius": 16 }
    },
    {
      "selector": "View.toolbar",
      "style": { "bgColor": "#12161E" }
    },
    {
      "selector": "View.card",
      "style": { "bgColor": "#1A2030", "borderRadius": 16 }
    },
    {
      "selector": "View.panel",
      "style": { "bgColor": "#1E2433", "borderRadius": 12 }
    },
    {
      "selector": "View.divider",
      "style": { "bgColor": "#2E3648" }
    },
    {
      "selector": "Label.title",
      "style": { "color": "#FFFFFF", "fontSize": 22, "fontWeight": "bold" }
    },
    {
      "selector": "Label.heading",
      "style": { "color": "#FFFFFF", "fontSize": 20, "fontWeight": "bold" }
    },
    {
      "selector": "Label.subtitle",
      "style": { "color": "#9AA3B2", "fontSize": 13 }
    },
    {
      "selector": "Label.body",
      "style": { "color": "#9AA3B2", "fontSize": 14 }
    },
    {
      "selector": "Label.caption",
      "style": { "color": "#6B7280", "fontSize": 10 }
    },
    {
      "selector": "Label.overline",
      "style": { "color": "#6B7280", "fontSize": 12, "fontWeight": "bold" }
    },
    {
      "selector": "Label.link",
      "style": { "color": "#7C6CFF", "fontSize": 12 }
    },
    {
      "selector": "Label.price",
      "style": { "color": "#E8C47C", "fontSize": 20, "fontWeight": "bold" }
    },
    {
      "selector": "Label.badge",
      "style": { "color": "#7C6CFF", "fontSize": 11, "fontWeight": "bold" }
    },
    {
      "selector": "Button.primary",
      "style": {
        "bgColor": "#7C6CFF",
        "color": "#FFFFFF",
        "fontWeight": "bold",
        "borderRadius": 10
      }
    },
    {
      "selector": "Button.secondary",
      "style": {
        "bgColor": "#1A2030",
        "color": "#F2F4F8",
        "borderRadius": 10
      }
    },
    {
      "selector": "Button.tertiary",
      "style": {
        "bgColor": "#1E2433",
        "color": "#C5CDDB",
        "borderRadius": 10
      }
    },
    {
      "selector": "Button.danger",
      "style": {
        "bgColor": "#1A2030",
        "color": "#EF5B5B",
        "borderRadius": 10
      }
    },
    {
      "selector": "Button.tone-a",
      "style": { "bgColor": "#1E2433", "color": "#E8E4FF", "fontWeight": "bold" }
    },
    {
      "selector": "Button.tone-b",
      "style": { "bgColor": "#1E2433", "color": "#FFE8F0", "fontWeight": "bold" }
    },
    {
      "selector": "Button.tone-c",
      "style": { "bgColor": "#1E2433", "color": "#E8F4FF", "fontWeight": "bold" }
    },
    {
      "selector": "Button.compact",
      "style": { "fontSize": 12, "borderRadius": 8 }
    },
    {
      "selector": "Button.block",
      "style": { "borderRadius": 10 }
    },
    {
      "selector": "Menu",
      "style": {
        "bgColor": "#12161E",
        "textColor": "#F2F4F8",
        "hoverColor": "#1E2433",
        "disabledColor": "#6B7280",
        "separatorColor": "#2E3648",
        "itemHeight": 29
      }
    },
    {
      "selector": "Dialog",
      "style": {
        "titleColor": "#7C6CFF",
        "textColor": "#F2F4F8",
        "bgColor": "#12161E",
        "borderColor": "#2E3648",
        "buttonColor": "#1A2030",
        "buttonHoverColor": "#1E2433",
        "buttonTextColor": "#F2F4F8"
      }
    },
    {
      "selector": "Text",
      "style": {
        "color": "#F2F4F8",
        "bgColor": "#0A0D12",
        "fontSize": 13,
        "lineNumberBgColor": "#12161E",
        "lineNumberColor": "#6B7280",
        "cursorColor": "#7C6CFF",
        "selectionColor": "#2E364899",
        "keyword": "#A78BFA",
        "string": "#6EE7B7",
        "number": "#FBBF24",
        "comment": "#6B7280",
        "punctuation": "#93C5FD"
      }
    },
    {
      "selector": "Table",
      "style": {
        "color": "#F2F4F8",
        "bgColor": "#0A0D12",
        "headerBgColor": "#12161E",
        "headerColor": "#9AA3B2",
        "gridLineColor": "#2E3648",
        "rowAltBgColor": "#12161E",
        "rowHoverColor": "#1E2433",
        "rowSelectedColor": "#2E3648"
      }
    },
    {
      "selector": "Sash",
      "style": {
        "bgColor": "#2E3648",
        "hoverBgColor": "#1E2433",
        "borderColor": "#2E3648",
        "dotColor": "#6B7280",
        "hoverDotColor": "#9AA3B2",
        "accentColor": "#7C6CFFB3"
      }
    },
    {
      "selector": "Checkbox",
      "style": {
        "bgColor": "#1A2030",
        "borderColor": "#2E3648",
        "checkColor": "#6EE7B7"
      }
    },
    {
      "selector": "View.tabBar",
      "style": {
        "bgColor": "#12161E",
        "borderBottomWidth": 1,
        "borderBottomColor": "#2E3648"
      }
    },
    {
      "selector": "Label.tab",
      "style": {
        "color": "#6B7280",
        "fontSize": 11,
        "padding": [4, 10, 4, 10],
        "borderRadius": 4,
        "bgColor": "transparent"
      }
    },
    {
      "selector": "Label.tab.active",
      "style": {
        "color": "#F2F4F8",
        "bgColor": "#1A2030",
        "fontSize": 11,
        "padding": [4, 10, 4, 10],
        "borderRadius": 4
      }
    },
    {
      "selector": "Label.tabAdd",
      "style": {
        "color": "#6B7280",
        "fontSize": 14
      }
    }
  ]
}
