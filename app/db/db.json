{
  "id": "dbEditor",
  "text": "DB",
  "type": "View",
  "size": [900, 600],
  "js": ["./db.js"],
  "icon": "app/db/icon.png",
  "layout": { "type": "absolute" },
  "style": {
    "titleBarBgColor": "#1E1E2E",
    "color": "#CDD6F4",
    "bgColor": "#1E1E2E"
  },
  "children": [
        {
          "position": [0, 0],
          "id": "toolbar",
          "type": "View",
          "size": [900, 30],
          "layout": {
            "type": "horizontal",
            "spacing": 0,
            "padding": [0, 0, 0, 0],
            "align": "center"
          },
          "style": {
            "bgColor": "#181825",
            "borderBottomWidth": 1,
            "borderBottomColor": "#313244"
          },
          "children": []
        },
        {
          "id": "mainContent",
        "type": "View",
        "position": [0, 36],
            "layout": {
              "type": "horizontal",
              "spacing": 0,
              "padding": [0, 0, 0, 0]
            },
        "size": [900, 534],
        "style": {
          "bgColor": "#1E1E2E"
        },
        "children": [
          {
            "id": "dbListPanel",
            "type": "View",
            "size": [240, 534],
            "layout": {
              "type": "vertical",
              "spacing": 6,
              "padding": [8, 8, 8, 8]
            },
            "style": {
              "bgColor": "#181825",
              "borderRightWidth": 1,
              "borderRightColor": "#313244"
            },
            "children": [
              {
                "id": "dbListHeader",
                "type": "View",
                "size": [224, 32],
                "layout": {
                  "type": "horizontal",
                  "align": "center",
                  "padding": [8, 12, 8, 12]
                },
                "style": {
                  "bgColor": "#181825",
                  "borderBottomWidth": 1,
                  "borderBottomColor": "#313244"
                },
                "children": [
                  {
                    "id": "dbListTitle",
                    "type": "Label",
                    "text": "数据库",
                    "style": {
                      "color": "#A6ADC8",
                      "fontSize": 11,
                      "fontWeight": "bold"
                    }
                  }
                ]
              },
              {
                "id": "dbListSearch",
                "type": "Input",
                "size": [224, 24],
                "text": "",
                "placeholder": "搜索表...",
                "style": {
                  "color": "#CDD6F4",
                  "bgColor": "#1E1E2E",
                  "fontSize": 11,
                  "padding": [6, 10, 6, 10]
                },
                "events": {
                  "onChange": "@onSearchDb"
                }
              },
              {
                "id": "dbTree",
                "type": "Treeview",
                "size": [224, 470],
                "scrollable": 1,
                "style": {
                  "color": "#CDD6F4",
                  "bgColor": "#181825",
                  "fontSize": 13
                },
                "events": {
                  "onSelect": "@onDbSelect",
                  "onExpand": "@onDbExpand"
                }
              }
            ]
          },
          {
            "id": "editorPanel",
            "type": "View",
            "size": [660, 534],
            "layout": {
              "type": "vertical",
              "spacing": 0
            },
            "style": {
              "bgColor": "#1E1E2E"
            },
            "children": [
              {
                "id": "sqlEditorContainer",
                "type": "View",
                "size": [660, 200],
                "layout": {
                  "type": "vertical",
                  "spacing": 0
                },
                "style": {
                  "bgColor": "#11111B"
                },
                "children": [
                  {
                    "id": "sqlToolbar",
                    "type": "View",
                    "size": [660, 32],
                    "layout": {
                      "type": "horizontal",
                      "spacing": 4,
                      "padding": [6, 12, 6, 12],
                      "align": "center"
                    },
                    "style": {
                      "bgColor": "#181825",
                      "borderBottomWidth": 1,
                      "borderBottomColor": "#313244"
                    },
                    "children": [
                      {
                        "id": "btnConnect",
                        "type": "Button",
                        "size": [48, 24],
                        "text": "连接",
                        "style": {
                          "color": "#CDD6F4",
                          "bgColor": "#45475A",
                          "borderRadius": 4,
                          "fontSize": 11
                        },
                        "events": { "onClick": "@connectDb" }
                      },
                      {
                        "id": "btnRun",
                        "type": "Button",
                        "size": [48, 24],
                        "icon": "app/assets/icons/run.svg",
                        "text": "运行",
                        "style": {
                          "color": "#A6E3A1",
                          "bgColor": "#313244",
                          "borderRadius": 4,
                          "fontSize": 11
                        },
                        "events": { "onClick": "@executeQuery" }
                      },
                      {
                        "id": "btnExplain",
                        "type": "Button",
                        "size": [28, 22],
                        "icon": "app/assets/icons/btnExplain.svg",
                        "style": {
                          "color": "#F9E2AF",
                          "bgColor": "transparent",
                          "fontSize": 12,
                          "borderRadius": 3
                        },
                        "events": { "onClick": "@onExplain" }
                      },
                      {
                        "id": "btnFormat",
                        "type": "Button",
                        "size": [28, 22],
                        "icon": "app/assets/icons/btnFormat.svg",
                        "style": {
                          "color": "#89B4FA",
                          "bgColor": "transparent",
                          "fontSize": 13,
                          "borderRadius": 3
                        },
                        "events": { "onClick": "@onFormat" }
                      },
                      {
                        "id": "btnSave",
                        "type": "Button",
                        "size": [28, 22],
                        "icon": "app/assets/icons/btnSave.svg",
                        "style": {
                          "color": "#A6ADC8",
                          "bgColor": "transparent",
                          "fontSize": 12,
                          "borderRadius": 3
                        },
                        "events": { "onClick": "@onSave" }
                      },
                      {
                        "id": "btnOpen",
                        "type": "Button",
                        "size": [28, 22],
                        "icon": "app/assets/icons/btnOpen.svg",
                        "style": {
                          "color": "#A6ADC8",
                          "bgColor": "transparent",
                          "fontSize": 12,
                          "borderRadius": 3
                        },
                        "events": { "onClick": "@onOpen" }
                      },
                      {
                        "id": "btnClear",
                        "type": "Button",
                        "size": [48, 24],
                        "text": "清空",
                        "style": {
                          "color": "#F38BA8",
                          "bgColor": "#313244",
                          "borderRadius": 4,
                          "fontSize": 11
                        },
                        "events": { "onClick": "@clearEditor" }
                      }
                    ]
                  },
                  {
                    "id": "sqlTabBar",
                    "type": "View",
                    "size": [660, 28],
                    "layout": {
                      "type": "horizontal",
                      "spacing": 0,
                      "padding": [6, 12, 6, 12],
                      "align": "center"
                    },
                    "style": {
                      "bgColor": "#11111B",
                      "borderBottomWidth": 1,
                      "borderBottomColor": "#313244"
                    },
                    "children": [
                      {
                        "id": "sqlTabs",
                        "type": "View",
                        "size": [600, 28],
                        "layout": {
                          "type": "horizontal",
                          "spacing": 0,
                          "align": "center"
                        },
                        "children": [
                          {
                            "id": "tab_0",
                            "type": "Label",
                            "text": "Query 1",
                            "style": {
                              "color": "#CDD6F4",
                              "bgColor": "#1E1E2E",
                              "fontSize": 11,
                              "padding": [4, 10, 4, 10],
                              "borderRadius": 4
                            },
                            "events": { "onClick": "@onTabClick" }
                          },
                          {
                            "id": "tab_1",
                            "type": "Label",
                            "text": "",
                            "visible": false,
                            "style": {
                              "color": "#6C7086",
                              "fontSize": 11,
                              "padding": [4, 10, 4, 10],
                              "borderRadius": 4
                            },
                            "events": { "onClick": "@onTabClick" }
                          },
                          {
                            "id": "tab_2",
                            "type": "Label",
                            "text": "",
                            "visible": false,
                            "style": {
                              "color": "#6C7086",
                              "fontSize": 11,
                              "padding": [4, 10, 4, 10],
                              "borderRadius": 4
                            },
                            "events": { "onClick": "@onTabClick" }
                          },
                          {
                            "id": "tab_3",
                            "type": "Label",
                            "text": "",
                            "visible": false,
                            "style": {
                              "color": "#6C7086",
                              "fontSize": 11,
                              "padding": [4, 10, 4, 10],
                              "borderRadius": 4
                            },
                            "events": { "onClick": "@onTabClick" }
                          },
                          {
                            "id": "tab_4",
                            "type": "Label",
                            "text": "",
                            "visible": false,
                            "style": {
                              "color": "#6C7086",
                              "fontSize": 11,
                              "padding": [4, 10, 4, 10],
                              "borderRadius": 4
                            },
                            "events": { "onClick": "@onTabClick" }
                          }
                        ]
                      },
                      {
                        "id": "newTabBtn",
                        "type": "Label",
                        "text": "+",
                        "style": {
                          "color": "#6C7086",
                          "fontSize": 14
                        },
                        "events": { "onClick": "@onNewTab" }
                      }
                    ]
                  },
                  {
                    "id": "sqlEditor",
                    "type": "Text",
                    "text": "",
                    "size": [660, 140],
                    "multiline": true,
                    "editable": true,
                    "scrollable": 1,
                    "events": {
                      "onChange": "@onSqlChange"
                    },
                    "style": {
                      "color": "#CDD6F4",
                      "bgColor": "#11111B",
                      "fontSize": 13,
                      "padding": [12, 12, 12, 12],
                      "cursorColor": "#89B4FA"
                    }
                  }
                ]
              },
              {
                "id": "resultContainer",
                "type": "View",
                "size": [660, 334],
                "layout": {
                  "type": "vertical",
                  "spacing": 0
                },
                "style": {
                  "bgColor": "#11111B"
                },
                "children": [
                  {
                    "id": "resultTabBar",
                    "type": "View",
                    "size": [660, 32],
                    "layout": {
                      "type": "horizontal",
                      "spacing": 12,
                      "padding": [8, 12, 8, 12],
                      "align": "center"
                    },
                    "style": {
                      "bgColor": "#181825",
                      "borderBottomWidth": 1,
                      "borderBottomColor": "#313244"
                    },
                    "children": [
                      {
                        "id": "resultTab",
                        "type": "Label",
                        "text": "查询结果",
                        "style": {
                          "color": "#CDD6F4",
                          "fontSize": 12
                        }
                      },
                      {
                        "id": "resultInfo",
                        "type": "Label",
                        "text": "(0 行)",
                        "style": {
                          "color": "#6C7086",
                          "fontSize": 11
                        }
                      }
                    ]
                  },
                  {
                    "id": "resultGrid",
                    "type": "Treeview",
                    "size": [660, 302],
                    "style": {
                      "color": "#CDD6F4",
                      "bgColor": "#11111B",
                      "fontSize": 13
                    }
                  }
                ]
              }
            ]
          }
      ]
    },
    {
      "id": "fileMenuPopup",
      "type": "Menu",
      "position": [0, 0],
      "size": [40, 175],
      "text": "文件",
      "fontSize": 12,
      "style": {
        "itemHeight": 29,
        "bgColor": "#1E1E2E",
        "textColor": "#CDD6F4",
        "hoverColor": "#45475A",
        "disabledColor": "#6C7086",
        "separatorColor": "#585B70"
      },
      "items": [
        { "text": "新建查询", "onClick": "onNewTab" },
        { "text": "打开文件", "onClick": "onOpen" },
        { "text": "保存文件", "onClick": "onSave" },
        { "separator": true },
        { "text": "退出", "onClick": "onExit" }
      ],
      "events": {
            "onItemClick": "@handleMenuClick"
        }
    },
    {
      "id": "dbMenuPopup",
      "type": "Menu",
      "position": [80, 0],
      "size": [40, 175],
      "text": "数据库",
      "fontSize": 12,
      "style": {
        "itemHeight": 29,
        "bgColor": "#1E1E2E",
        "textColor": "#CDD6F4",
        "hoverColor": "#45475A",
        "disabledColor": "#6C7086",
        "separatorColor": "#585B70"
      },
      "items": [
        { "text": "新建连接", "onClick": "onNewConnection" },
        { "text": "连接数据库", "onClick": "connectDb" },
        { "text": "断开连接", "onClick": "disconnectDb" },
        { "separator": true },
        { "text": "导入数据库", "onClick": "onImportDb" }
      ],
      "events": {
            "onItemClick": "@handleMenuClick"
        }
    },
    {
      "id": "settingsMenuPopup",
      "type": "Menu",
      "position": [164, 0],
      "size": [40, 146],
      "text": "设置",
      "fontSize": 12,
      "style": {
        "itemHeight": 29,
        "bgColor": "#1E1E2E",
        "textColor": "#CDD6F4",
        "hoverColor": "#45475A",
        "disabledColor": "#6C7086",
        "separatorColor": "#585B70"
      },
      "items": [
        { "text": "偏好设置", "onClick": "onOpenSettings" },
        { "text": "主题设置", "onClick": "onThemeSettings" },
        { "separator": true },
        { "text": "关于", "onClick": "onAbout" }
      ],
      "events": {
            "onItemClick": "@handleMenuClick"
        }
    },
    {
      "id": "statusBar",
      "type": "View",
      "position": [0, 570],
      "size": [900, 30],
      "layout": {
        "type": "horizontal",
        "spacing": 12,
        "padding": [8, 12, 8, 12],
        "align": "center"
      },
      "style": {
        "bgColor": "#181825",
        "borderTopWidth": 1,
        "borderTopColor": "#313244"
      },
      "children": [
        {
          "id": "statusIcon",
          "type": "Label",
          "text": "●",
          "style": {
            "color": "#F38BA8",
            "fontSize": 10
          }
        },
        {
          "id": "statusText",
          "type": "Label",
          "text": "未连接",
          "size": [300, 20],
          "style": {
            "color": "#CDD6F4",
            "fontSize": 11,
            "fontWeight": "bold"
          }
        }
      ]
    },
    {
      "id": "aboutDialog",
      "type": "Dialog",
      "title": "关于 YUI",
      "message": "YUI - Ya Ya User Interface\n\n一款面向 AI 应用的轻量级 GUI 框架，由 evilbinary 开发，使用 C 语言构建，通过 JSON 描述界面。\n\n主要特性：\n• 轻量高性能，支持脏矩形渲染\n• 声明式 JSON 配置 UI\n• 跨平台（Windows / macOS / Linux）\n• 丰富组件、动画系统、主题切换\n• 支持 QuickJS / mquickjs / Mario 引擎\n\n许可证：LGPL-2.1\n项目地址：github.com/evilbinary/YUI\n\nYUI DB Editor v0.1",
      "dialogType": "info",
      "modal": true,
      "size": [360, 240],
      "buttons": [
        { "text": "确定", "default": true }
      ],
      "style": {
        "titleColor": "#89B4FA",
        "textColor": "#CDD6F4",
        "bgColor": "#1E1E2E",
        "borderColor": "#45475A",
        "buttonColor": "#45475A",
        "buttonHoverColor": "#585B70",
        "buttonTextColor": "#CDD6F4"
      }
    }
  ],
  "events": {
    "onLoad": "@onLoad"
  }
}
