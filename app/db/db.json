                  "events": { "onClick": "@onFileBrowserCancel" }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "connectionDialogOverlay",
      "type": "View",
      "visible": false,
      "position": [0, 0],
      "size": [900, 600],
      "style": { "bgColor": "#00000066" },
      "layout": { "type": "absolute" },
      "children": [
        {
          "id": "connectionDialogPanel",
          "type": "View",
          "position": [200, 100],
          "size": [500, 380],
          "layout": { "type": "vertical", "spacing": 0 },
          "style": { "bgColor": "#1E1E2E", "borderRadius": 8 },
          "children": [
            {
              "id": "connectionDialogTitleBar",
              "type": "View",
              "size": [500, 40],
              "layout": { "type": "horizontal", "align": "center", "justify": "space-between", "padding": [0, 12, 0, 12] },
              "style": { "bgColor": "#181825", "borderBottomWidth": 1, "borderBottomColor": "#313244" },
