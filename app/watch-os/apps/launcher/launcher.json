{
    "id": "page_launcher",
    "js": ["launcher.js"],
    "type": "View",
    "variant": "surface",
    "flex": 1,
    "scrollable": 1,
    "layout": { "type": "vertical", "spacing": 6, "padding": [4, 16, 12, 16] },
    "events": { "onLoad": "@onLauncherLoad", "onShow": "@onLauncherShow" },
    "children": [
        { "id": "launcher_brand", "type": "Label", "variant": "overline", "text": "APP GRID" },
        { "id": "launcher_title", "type": "Label", "variant": "title", "text": "应用" },
        { "id": "row_app_health", "type": "Button", "variants": ["block", "tone-a"], "text": "🩺  健康", "size": [358, 48], "events": { "onClick": "@openHealth" } },
        { "id": "row_app_timer", "type": "Button", "variants": ["block", "tone-c"], "text": "⏱  计时器", "size": [358, 48], "events": { "onClick": "@openTimer" } },
        { "id": "row_app_calc", "type": "Button", "variants": ["block", "tone-b"], "text": "🧮  计算器", "size": [358, 48], "events": { "onClick": "@openCalc" } },
        { "id": "row_app_settings", "type": "Button", "variants": ["block", "tertiary"], "text": "⚙  设置", "size": [358, 48], "events": { "onClick": "@openSettings" } },
        { "id": "launcher_soon", "type": "Label", "variant": "overline", "text": "即将推出" },
        { "id": "row_soon_workout", "type": "Button", "variant": "ghost", "text": "🏃  训练", "size": [358, 44] },
        { "id": "row_soon_phone", "type": "Button", "variant": "ghost", "text": "📞  电话", "size": [358, 44] },
        { "id": "row_soon_maps", "type": "Button", "variant": "ghost", "text": "🗺  地图", "size": [358, 44] },
        { "id": "row_soon_wallet", "type": "Button", "variant": "ghost", "text": "💳  钱包", "size": [358, 44] }
    ]
}
