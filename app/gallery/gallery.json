              "type": "View",
              "size": [900, 40],
              "layout": { "type": "horizontal", "spacing": 16, "align": "center" },
              "children": [
                {
                  "id": "gallerySelect",
                  "type": "Select",
                  "size": [220, 32],
                  "selectConfig": {
                    "placeholder": "请选择",
                    "itemHeight": 28,
                    "maxVisibleItems": 6,
                    "items": ["选项一", "选项二", "选项三", "选项四"]
