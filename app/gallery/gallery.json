                {
                  "id": "gallerySplitRight",
                  "type": "View",
                  "variant": "elevated",
                  "size": [594, 100],
                  "layout": { "type": "vertical", "padding": [12, 12, 12, 12] },
                  "children": [
                    { "type": "Label", "variant": "body", "text": "右侧面板 — 拖动中间 Sash" }
                  ]
                }
              ]
            }
          ]
