{
  "name": "element-plus",
  "version": "1.0",
  "description": "Element Plus 亮色主题（模拟 Vue Element Plus 默认风格）",
  "styles": [
    { "selector": "View", "style": { "bgColor": "#F2F3F5" } },

    { "selector": "Label", "style": { "color": "#303133", "fontSize": 12 } },

    {
      "selector": "Button",
      "style": {
        "bgColor": "#FFFFFF",
        "color": "#606266",
        "borderRadius": 4,
        "fontSize": 12
      }
    },

    {
      "selector": "Input",
      "style": {
        "bgColor": "#FFFFFF",
        "color": "#606266",
        "fontSize": 12,
        "borderRadius": 4,
        "borderColor": "#DCDFE6",
        "focusBorderColor": "#409EFF"
      }
    },

    {
      "selector": "Text",
      "style": {
        "color": "#303133",
        "bgColor": "#FFFFFF",
        "fontSize": 13,
        "lineNumberBgColor": "#F5F7FA",
        "lineNumberColor": "#909399",
        "cursorColor": "#409EFF",
        "selectionColor": "#409EFF33",
        "keyword": "#409EFF",
        "string": "#67C23A",
        "number": "#E6A23C",
        "comment": "#909399",
        "punctuation": "#606266"
      }
    },

    {
      "selector": "Table",
      "style": {
        "color": "#606266",
        "bgColor": "#FFFFFF",
        "headerBgColor": "#F5F7FA",
        "headerColor": "#909399",
        "gridLineColor": "#EBEEF5",
        "rowAltBgColor": "#FAFAFA",
        "rowHoverColor": "#F5F7FA",
        "rowSelectedColor": "#ECF5FF",
        "cellFocusColor": "#ECF5FF",
        "scrollbarColor": "#C0C4CC",
        "scrollbarTrackColor": "#F5F7FA80"
      }
    },

    {
      "selector": "Treeview",
      "style": {
        "color": "#606266",
        "bgColor": "#FFFFFF",
        "fontSize": 13,
        "selectedBgColor": "#ECF5FF",
        "hoverBgColor": "#F5F7FA",
        "scrollbarColor": "#C0C4CC",
        "scrollbarTrackColor": "#F5F7FA80"
      }
    },

    {
      "selector": "Pagination",
      "style": {
        "color": "#606266",
        "buttonBgColor": "#F5F7FA",
        "buttonHoverColor": "#E4E7ED"
      }
    },

    {
      "selector": "Sash",
      "style": {
        "bgColor": "#E4E7ED",
        "hoverBgColor": "#DCDFE6",
        "borderColor": "#DCDFE6",
        "dotColor": "#C0C4CC",
        "hoverDotColor": "#909399",
        "accentColor": "#409EFFB3"
      }
    },

    {
      "selector": "Checkbox",
      "style": {
        "bgColor": "#FFFFFF",
        "borderColor": "#DCDFE6",
        "checkColor": "#409EFF"
      }
    },

    {
      "selector": "Menu",
      "style": {
        "bgColor": "#FFFFFF",
        "textColor": "#303133",
        "hoverColor": "#ECF5FF",
        "disabledColor": "#C0C4CC",
        "separatorColor": "#EBEEF5",
        "itemHeight": 34
      }
    },

    {
      "selector": "Dialog",
      "style": {
        "titleColor": "#303133",
        "textColor": "#606266",
        "bgColor": "#FFFFFF",
        "borderColor": "#E4E7ED",
        "buttonColor": "#FFFFFF",
        "buttonHoverColor": "#ECF5FF",
        "buttonTextColor": "#409EFF"
      }
    },

    {
      "selector": "View.tabBar",
      "style": {
        "bgColor": "#FFFFFF",
        "borderBottomWidth": 1,
        "borderBottomColor": "#E4E7ED"
      }
    },
    {
      "selector": "Label.tab",
      "style": {
        "color": "#303133",
        "fontSize": 12,
        "padding": [4, 16, 4, 16],
        "borderRadius": 0,
        "bgColor": "transparent"
      }
    },
    {
      "selector": "Label.tab.active",
      "style": {
        "color": "#409EFF",
        "bgColor": "transparent",
        "fontSize": 12,
        "padding": [4, 16, 4, 16],
        "borderRadius": 0
      }
    },
    {
      "selector": "Label.tabAdd",
      "style": {
        "color": "#909399",
        "fontSize": 14
      }
    },
    {
      "selector": "View.settingsCard",
      "style": {
        "bgColor": "#FFFFFF",
        "borderRadius": 8,
        "borderWidth": 1,
        "borderColor": "#E4E7ED"
      }
    },
    {
      "selector": "#preferencesDialogFrame",
      "style": {
        "bgColor": "#DCDFE6",
        "borderRadius": 9
      }
    },
    {
      "selector": "Label.navItem",
      "style": {
        "color": "#606266",
        "fontSize": 12,
        "padding": [8, 12, 8, 12],
        "borderRadius": 6,
        "bgColor": "transparent"
      }
    },
    {
      "selector": "Label.navItem.active",
      "style": {
        "color": "#409EFF",
        "fontSize": 12,
        "padding": [8, 12, 8, 12],
        "borderRadius": 6,
        "bgColor": "#ECF5FF"
      }
    },
    {
      "selector": "Label.sectionTitle",
      "style": {
        "color": "#909399",
        "fontSize": 11,
        "fontWeight": "bold"
      }
    }
  ]
}
