{
    "id": "page_face",
    "js": ["face.js"],
    "type": "View",
    "variant": "surface",
    "flex": 1,
    "layout": {
        "type": "vertical",
        "spacing": 12,
        "padding": [8, 20, 16, 20]
    },
    "events": {
        "onLoad": "@onFaceLoad",
        "onShow": "@onFaceShow",
        "onHide": "@onFaceHide"
    },
    "children": [
        {
            "id": "watch_face_container",
            "type": "View",
            "flex": 1,
            "layout": { "type": "vertical", "spacing": 18, "align": "center" },
            "children": [
                {
                    "id": "face_time",
                    "type": "Label",
                    "variant": "watch-digital",
                    "text": "10:09",
                    "size": [350, 72]
                },
                {
                    "id": "activity_rings",
                    "type": "View",
                    "size": [350, 96],
                    "layout": { "type": "horizontal", "spacing": 18, "align": "center" },
                    "children": [
                        {
                            "id": "ring_move",
                            "type": "Progress",
                            "size": [64, 64],
                            "shape": "circle",
                            "value": 75,
                            "showPercentage": false,
                            "fillColor": "#FA114F",
                            "style": { "bgColor": "#333333", "circleWidth": 7 }
                        },
                        {
                            "id": "ring_exercise",
                            "type": "Progress",
                            "size": [84, 84],
                            "shape": "circle",
                            "value": 60,
                            "showPercentage": false,
                            "fillColor": "#2ECC71",
                            "style": { "bgColor": "#333333", "circleWidth": 8 }
                        },
                        {
                            "id": "ring_stand",
                            "type": "Progress",
                            "size": [64, 64],
                            "shape": "circle",
                            "value": 90,
                            "showPercentage": false,
                            "fillColor": "#3498DB",
                            "style": { "bgColor": "#333333", "circleWidth": 7 }
                        }
                    ]
                }
            ]
        },
        {
            "id": "dock",
            "type": "View",
            "size": [350, 76],
            "layout": { "type": "horizontal", "spacing": 12, "align": "center" },
            "children": [
                {
                    "id": "dock_health",
                    "type": "Button",
                    "variant": "dock-health",
                    "text": "🩺",
                    "size": [68, 68],
                    "events": { "onClick": "@openHealth" }
                },
                {
                    "id": "dock_timer",
                    "type": "Button",
                    "variant": "dock-timer",
                    "text": "⏱",
                    "size": [68, 68],
                    "events": { "onClick": "@openTimer" }
                },
                {
                    "id": "dock_calc",
                    "type": "Button",
                    "variant": "dock-calc",
                    "text": "🧮",
                    "size": [68, 68],
                    "events": { "onClick": "@openCalc" }
                },
                {
                    "id": "dock_launcher",
                    "type": "Button",
                    "variant": "dock-more",
                    "text": "⊞",
                    "size": [68, 68],
                    "events": { "onClick": "@openLauncher" }
                }
            ]
        }
    ]
}
