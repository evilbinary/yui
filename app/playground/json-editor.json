{
    "id": "jsonEditorApp",
    "type": "View",
    "size": [1200, 900],
    "style": {
        "bgColor": "#ffffff"
    },
    "js": ["../lib/http.js","api-client.js", "json-editor.js"],
    "layout": {
        "type": "vertical",
        "spacing": 0
    },
    "children": [
        {
            "id": "contentPanel",
            "type": "View",
            "size": [0, 0],
            "flex": 1,
            "layout": {
                "type": "horizontal",
                "spacing": 0
            },
            "children": [
                {
                    "id": "editorPanel",
                    "type": "View",
                    "size": [600, 0],
                    "style": {
                        "bgColor": "#2b2b2b",
                        "borderWidth": 1,
                        "borderColor": "#cccccc"
                    },
                    "layout": {
                        "type": "vertical",
                        "spacing": 0
                    },
                    "children": [
                        {
                            "id": "editorHeader",
                            "type": "View",
                            "size": [0, 40],
                            "style": {
                                "bgColor": "#1e1e1e",
                                "borderRadius": [8, 8, 0, 0],
                                "borderBottomWidth": 1,
                                "borderBottomColor": "#333333"
                            },
                            "layout": {
                                "type": "horizontal",
                                "spacing": 10,
                                "padding": [10, 10, 10, 10],
                                "justifyContent": "left"
                            },
                            "children": [
                                {
                                    "type": "Label",
                                    "label": "JSON编辑器",
                                    "text": "JSON编辑器",
                                    "size": [120, 20],
                                    "style": {
                                        "color": "#ffffff",
                                        "fontSize": 14
                                    }
                                },
                                {
                                    "id": "validateBtn",
                                    "type": "Button",
                                    "text": "验证",
                                    "size": [60, 25],
                                    "style": {
                                        "bgColor": "#4caf50",
                                        "color": "#ffffff",
                                        "fontSize": 12,
                                        "borderRadius": 4
                                    }
                                },
                                {
                                    "id": "formatBtn",
                                    "type": "Button",
                                    "text": "格式化",
                                    "size": [70, 25],
                                    "style": {
                                        "bgColor": "#2196f3",
                                        "color": "#ffffff",
                                        "fontSize": 12,
                                        "borderRadius": 4
                                    }
                                },
                                {
                                    "id": "inspectBtn",
                                    "type": "Button",
                                    "text": "Inspect",
                                    "size": [60, 25],
                                    "style": {
                                        "bgColor": "#ff9800",
                                        "color": "#ffffff",
                                        "fontSize": 12,
                                        "borderRadius": 4
                                    }
                                }
                            ]
                        },
                        {
                            "id": "jsonEditor",
                            "type": "Text",
                            "text": "",
                            "size": [0, 0],
                            "flex": 1,
                            "scrollable": 1,
                            "showLineNumbers":true,
                            "lineNumberWidth": 40,
                            "style": {
                                "bgColor": "#2b2b2b",
                                "color": "#f8f8f2",
                                "selectionColor": "#6BAF52CC",
                                "fontSize": 14,
                                "padding": [10, 10, 10, 10],
                                "fontFamily": "monospace",
                                "borderLeftWidth": 1,
                                "borderLeftColor": "#333333"
                            },
                            "editable": true,
                            "multiline": true,
                            "syntaxHighlight": "json"
                        }
                    ]
                },
                {
                    "id": "editorSash",
                    "type": "Sash",
                    "target": "editorPanel",
                    "orientation": "horizontal",
                    "minSize": 280,
                    "size": [6, 0],
                    "style": {
                        "bgColor": "#333333",
                        "hoverBgColor": "#4a4a4a",
                        "borderColor": "#1e1e1e",
                        "dotColor": "#666666",
                        "hoverDotColor": "#aaaaaa",
                        "accentColor": "#2196f3b3"
                    }
                },
                {
                    "id": "previewPanel",
                    "type": "View",
                    "style": {
                        "bgColor": "#000000",
                        "borderWidth": 1,
                        "borderColor": "#333333"
                    },
                    "layout": {
                        "type": "vertical",
                        "spacing": 0
                    },
                    "children": [
                        
                        {
                            "id": "previewLabel",
                            "type": "Label",
                            "text": "",
                            "size": [0, 0],
                            "flex": 1,
                            "layout":{
                                "type": "vertical",
                                "align": "center",
                                "justifyContent": "center",
                                "padding": [0, 0, 0, 0]
                            },
                            "scrollable": 2,
                            "style": {
                                "bgColor": "#000000",
                                "color": "#f8f8f2",
                                "fontSize": 13,
                                "fontFamily": "monospace",
                                "textAlign": "left",
                                "lineHeight": 1.5,
                                "padding": [20, 20, 20, 20],
                                "scrollable": true
                            }
                        },
                        {
                            "id": "aiLoadingMask",
                            "type": "View",
                            "visible": false,
                            "size": [0, 0],
                            "flex": 1,
                            "layout": {
                                "type": "center"
                            },
                            "style": {
                                "bgColor": "#000000"
                            },
                            "children": [
                                {
                                    "id": "aiLoading",
                                    "type": "Loading",
                                    "size": [72, 72],
                                    "variant": "spinner",
                                    "text": "AI 生成中...",
                                    "color": "#2196f3",
                                    "trackColor": "#333333",
                                    "strokeWidth": 4
                                }
                            ]
                        },
                        {
                            "id": "inputLabel",
                            "type": "Label",
                            "text": "",
                            "size": [0, 40],
                            "style": {
                                "bgColor": "#000000",
                                "color": "#f8f8f2",
                                "fontSize": 13,
                                "fontFamily": "monospace",
                                "textAlign": "left",
                                "lineHeight": 1.5,
                                "padding": [20, 20, 20, 20],
                                "scrollable": true
                            }
                        }
                    ]
                }
            ]
        },
        {
            "id": "inputContainer",
            "type": "View",
            "size": [0, 100],
            "layout": {
                "type": "horizontal",
                "spacing": 10,
                "padding": [10, 10, 10, 10],
                "justifyContent": "left",
                "align": "right"
            },
            "style": {
                "bgColor": "#1e1e1e",
                "borderTopWidth": 1,
                "borderTopColor": "#333333"
            },
            "children": [
                {
                    "id": "messageInput",
                    "type": "Text",
                    "text": "",
                    "placeholder": "输入需要生成的UI内容...",
                    "size": [0, 0],
                    "flex": 1,
                    "scrollable": 1,
                    "style": {
                        "bgColor": "#2b2b2b",
                        "color": "#f8f8f2",
                        "fontSize": 13,
                        "padding": [10, 10, 10, 10],
                        "borderWidth": 1,
                        "borderColor": "#444444",
                        "borderRadius": 4
                    },
                    "editable": true,
                    "multiline": true
                },
                {
                    "id": "updateModeSelect",
                    "type": "Select",
                    "text": "增量更新",
                    "size": [100, 35],
                    "style": {
                        "bgColor": "#2b2b2b",
                        "color": "#f8f8f2",
                        "fontSize": 13,
                        "borderWidth": 1,
                        "borderColor": "#444444",
                        "borderRadius": 4
                    },
                    "items": [
                        {"label": "增量更新", "value": "incremental"},
                        {"label": "全量更新", "value": "full"}
                    ]
                },
                {
                    "id": "sendBtn",
                    "type": "Button",
                    "text": "生成",
                    "size": [100, 35],
                    "style": {
                        "bgColor": "#2196f3",
                        "color": "#ffffff",
                        "fontSize": 13,
                        "borderRadius": 4,
                        "fontWeight": "bold"
                    }
                }
            ]
        }
    ],
    "events": {
        "onLoad": "@initJsonEditor",
        "jsonEditor.onChange": "@onJsonChange",
        "validateBtn.onClick": "@validateJson",
        "formatBtn.onClick": "@formatJson",
        "refreshBtn.onClick": "@refreshPreview",
        "sendBtn.onClick": "@sendMessage",
        "updateModeSelect.onChange": "@onUpdateModeChange",
        "inspectBtn.onClick": "@toggleInspect"
    }
}
