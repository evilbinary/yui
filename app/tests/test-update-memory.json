        },
        {
            "id": "previewLabel",
            "type": "View",
            "size": [0, 0],
            "flex": 1,
            "style": {
                "bgColor": "#11111b",
                "borderWidth": 1,
                "borderColor": "#313244"
            },
            "layout": {
                "type": "vertical",
                "spacing": 0
            },
            "children": []
        }
