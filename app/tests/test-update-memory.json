                    "size": [88, 32],
                    "style": {
                        "bgColor": "#a6e3a1",
                        "color": "#1e1e2e",
                        "fontSize": 12,
                        "borderRadius": 4
                    },
                    "events": { "onClick": "@togglePerfPoll" }
