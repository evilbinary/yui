            { "id": "btnThemeMocha", "type": "Button", "variant": "compact", "size": [110, 32], "text": "Mocha", "events": { "onClick": "@onThemeMocha" } },
            { "id": "btnThemeDark", "type": "Button", "variant": "compact", "size": [110, 32], "text": "Dark", "events": { "onClick": "@onThemeDark" } },
            { "id": "btnThemeLatte", "type": "Button", "variant": "compact", "size": [110, 32], "text": "Latte", "events": { "onClick": "@onThemeLatte" } },
            { "id": "btnThemeEp", "type": "Button", "variant": "compact", "size": [130, 32], "text": "Element Plus", "events": { "onClick": "@onThemeElementPlus" } },
            { "id": "btnThemeEpDark", "type": "Button", "variant": "compact", "size": [110, 32], "text": "EP Dark", "events": { "onClick": "@onThemeElementPlusDark" } },
            { "id": "btnThemeSoft", "type": "Button", "variant": "compact", "size": [110, 32], "text": "Soft UI", "events": { "onClick": "@onThemeSoftUi" } },
            { "id": "btnThemeSoftDark", "type": "Button", "variant": "compact", "size": [130, 32], "text": "Soft UI Dark", "events": { "onClick": "@onThemeSoftUiDark" } }
          ]
        },
        {
          "id": "galleryThemeRow2",
          "type": "View",
          "size": [948, 34],
          "layout": { "type": "horizontal", "spacing": 8, "align": "center" },
          "children": [
            { "id": "btnThemeTerminal", "type": "Button", "variant": "compact", "size": [160, 32], "text": "Terminal", "events": { "onClick": "@onThemeTerminal" } }
          ]
        }
      ]
    },
    {
      "id": "galleryContent",
      "type": "View",
      "variant": "surface",
      "size": [980, 564],
      "scrollable": 1,
      "layout": { "type": "vertical", "spacing": 16, "padding": [16, 16, 24, 16] },
      "children": [
        {
          "id": "secPerf",
          "type": "View",
          "variant": "card",
          "size": [948, 168],
          "layout": { "type": "vertical", "spacing": 8, "padding": [14, 16, 14, 16] },
          "children": [
            { "type": "Label", "variant": "sectionTitle", "size": [900, 18], "text": "YUI.perf 性能分析" },
            { "id": "galleryPerfStatus", "type": "Label", "variant": "subtitle", "size": [900, 20], "text": "状态：未启用" },
            { "id": "galleryPerfStats", "type": "Label", "variant": "caption", "size": [900, 48], "text": "统计：点击「刷新」查看 fps / renderMs / Top layers" },
            {
              "type": "View",
              "size": [900, 36],
              "layout": { "type": "horizontal", "spacing": 8, "align": "center" },
              "children": [
                { "id": "btnPerfHud", "type": "Button", "variant": "secondary", "size": [100, 32], "text": "HUD 关", "events": { "onClick": "@onPerfToggleHud" } },
                { "id": "btnPerfRefresh", "type": "Button", "variant": "secondary", "size": [90, 32], "text": "刷新", "events": { "onClick": "@onPerfRefresh" } },
                { "id": "btnPerfPoll", "type": "Button", "variant": "secondary", "size": [110, 32], "text": "自动刷新", "events": { "onClick": "@onPerfTogglePoll" } },
                { "id": "btnPerfExport", "type": "Button", "variant": "tertiary", "size": [90, 32], "text": "导出", "events": { "onClick": "@onPerfExport" } },
                { "id": "btnPerfReset", "type": "Button", "variant": "compact", "size": [90, 32], "text": "重置", "events": { "onClick": "@onPerfReset" } },
                { "id": "btnPerfDisable", "type": "Button", "variant": "danger", "size": [110, 32], "text": "关闭 perf", "events": { "onClick": "@onPerfDisable" } }
              ]
            }
          ]
