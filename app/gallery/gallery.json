        {
          "id": "secSash",
          "type": "View",
          "variant": "card",
          "size": [948, 160],
          "layout": { "type": "vertical", "spacing": 8, "padding": [14, 16, 14, 16] },
          "children": [
            { "type": "Label", "variant": "sectionTitle", "text": "Sash（分割条）" },
