          "type": "View",
          "size": [900, 30],
          "layout": {
            "type": "horizontal",
            "spacing": 0,
            "padding": [0, 0, 0, 0],
            "align": "center"
          },
          "style": {
            "bgColor": "#181825",
            "borderBottomWidth": 1,
            "borderBottomColor": "#313244"
          },
          "children": []
        },
        {
          "id": "mainContent",
        "type": "View",
        "position": [0, 36],
            "layout": {
              "type": "horizontal",
              "spacing": 0,
              "padding": [0, 0, 0, 0]
            },
        "size": [900, 534],
        "style": {
          "bgColor": "#1E1E2E"
        },
        "children": [
          {
            "id": "dbListPanel",
            "type": "View",
            "size": [240, 534],
            "layout": {
              "type": "vertical",
              "spacing": 6,
              "padding": [8, 8, 8, 8]
            },
            "style": {
              "bgColor": "#181825",
              "borderRightWidth": 1,
              "borderRightColor": "#313244"
            },
            "children": [
              {
                "id": "dbListHeader",
                "type": "View",
                "size": [224, 32],
                "layout": {
                  "type": "horizontal",
                  "align": "center",
                  "padding": [8, 12, 8, 12]
                },
                "style": {
                  "bgColor": "#181825",
                  "borderBottomWidth": 1,
                  "borderBottomColor": "#313244"
                },
                "children": [
                  {
                    "id": "dbListTitle",
                    "type": "Label",
                    "text": "数据库",
                    "style": {
                      "color": "#A6ADC8",
                      "fontSize": 11,
                      "fontWeight": "bold"
                    }
                  }
                ]
              },
              {
                "id": "dbListSearch",
                "type": "Input",
                "size": [224, 24],
                "text": "",
                "placeholder": "搜索表...",
                "style": {
                  "color": "#CDD6F4",
                  "bgColor": "#1E1E2E",
                  "fontSize": 11,
                  "padding": [6, 10, 6, 10]
