                { "id": "galleryInput1", "type": "Input", "size": [280, 36], "text": "", "placeholder": "请输入…" },
                { "id": "galleryInput2", "type": "Input", "size": [280, 36], "text": "已填写内容" }
              ]
            }
          ]
        },
        {
          "id": "secChecks",
