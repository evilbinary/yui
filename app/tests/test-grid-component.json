          "events": { "onClick": "@onCellClick" }
        }
      ]
    },
    {
      "id": "sectionB",
      "type": "Label",
      "text": "B. type=View + layout.type=grid，columns: 4",
      "size": [528, 20],
      "style": {
        "color": "#a6e3a1",
        "fontSize": 13
      }
    },
    {
      "id": "layoutGrid",
      "type": "View",
      "size": [528, 108],
