{
  "id": "dump_root",
  "type": "View",
  "size": [640, 400],
  "autoTest": true,
  "js": ["../lib/ytest.js", "test-layer-dump.js"],
  "style": {
    "bgColor": "#1e1e22",
    "borderRadius": 8
  },
  "events": {
    "onLoad": "@onTestLoad"
  },
  "layout": {
    "type": "vertical",
    "spacing": 12,
    "padding": [16, 16, 16, 16]
  },
  "children": [
    {
      "id": "dump_title",
      "type": "Label",
      "text": "Layer JSON Dump",
      "size": [608, 36],
      "style": {
        "color": "#ffffff",
        "fontSize": 18,
        "bgColor": "#2d6cdf",
        "borderRadius": 6
      }
    },
    {
      "id": "dump_status",
      "type": "Label",
      "text": "ready",
      "size": [608, 28],
      "style": {
        "color": "#cccccc",
        "fontSize": 14
      }
    }
  ]
}
