{
  "name": "soft-ui-dark",
  "version": "1.0",
  "description": "Soft UI 柔和界面风（暗色）- 大圆角、低饱和、避免纯黑",
  "styles": [
    { "selector": "View", "style": { "bgColor": "#111827" } },
    { "selector": "Label", "style": { "color": "#E5E7EB", "fontSize": 14 } },
    {
      "selector": "Button",
      "style": {
        "bgColor": "#1F2937",
        "color": "#E5E7EB",
        "fontSize": 14,
        "borderRadius": 16
      }
    },
    {
      "selector": "Input",
      "style": {
        "bgColor": "#1F2937",
        "color": "#E5E7EB",
        "fontSize": 14,
        "borderRadius": 16,
        "borderColor": "transparent",
        "focusBorderColor": "#818CF8"
      }
    },
    { "selector": "Image", "style": { "bgColor": "#1F2937", "borderRadius": 16 } },
    { "selector": "View.surface", "style": { "bgColor": "#111827" } },
    { "selector": "View.elevated", "style": { "bgColor": "#1F2937", "borderRadius": 20 } },
    { "selector": "View.toolbar", "style": { "bgColor": "#1F2937" } },
    {
      "selector": "View.card",
      "style": {
        "bgColor": "#1F2937",
        "borderRadius": 24
      }
    },
    { "selector": "View.panel", "style": { "bgColor": "#312E81", "borderRadius": 20 } },
    { "selector": "View.divider", "style": { "bgColor": "#374151" } },
    { "selector": "Label.title", "style": { "color": "#F9FAFB", "fontSize": 22, "fontWeight": "bold" } },
    { "selector": "Label.heading", "style": { "color": "#F9FAFB", "fontSize": 20, "fontWeight": "bold" } },
    { "selector": "Label.subtitle", "style": { "color": "#9CA3AF", "fontSize": 13 } },
    { "selector": "Label.body", "style": { "color": "#D1D5DB", "fontSize": 14 } },
    { "selector": "Label.caption", "style": { "color": "#9CA3AF", "fontSize": 12 } },
    { "selector": "Label.overline", "style": { "color": "#9CA3AF", "fontSize": 12, "fontWeight": "bold" } },
    { "selector": "Label.link", "style": { "color": "#818CF8", "fontSize": 12 } },
    { "selector": "Label.price", "style": { "color": "#FBBF24", "fontSize": 20, "fontWeight": "bold" } },
    { "selector": "Label.badge", "style": { "color": "#818CF8", "fontSize": 11, "fontWeight": "bold" } },
    {
      "selector": "Button.primary",
      "style": {
        "bgColor": "#6366F1",
        "color": "#FFFFFF",
        "fontWeight": "bold",
        "borderRadius": 16
      }
    },
    {
      "selector": "Button.secondary",
      "style": {
        "bgColor": "#374151",
        "color": "#E5E7EB",
        "borderRadius": 16
      }
    },
    {
      "selector": "Button.tertiary",
      "style": {
        "bgColor": "#312E81",
        "color": "#C7D2FE",
        "borderRadius": 16
      }
    },
    {
      "selector": "Button.danger",
      "style": {
        "bgColor": "#3F1D1D",
        "color": "#FCA5A5",
        "borderRadius": 16
      }
    },
    { "selector": "Button.tone-a", "style": { "bgColor": "#312E81", "color": "#C7D2FE", "fontWeight": "bold" } },
    { "selector": "Button.tone-b", "style": { "bgColor": "#064E3B", "color": "#6EE7B7", "fontWeight": "bold" } },
    { "selector": "Button.tone-c", "style": { "bgColor": "#451A03", "color": "#FCD34D", "fontWeight": "bold" } },
    { "selector": "Button.compact", "style": { "fontSize": 12, "borderRadius": 14 } },
    { "selector": "Button.block", "style": { "borderRadius": 16 } },
    {
      "selector": "Menu",
      "style": {
        "bgColor": "#1F2937",
        "textColor": "#E5E7EB",
        "hoverColor": "#312E81",
        "disabledColor": "#6B7280",
        "separatorColor": "#374151",
        "itemHeight": 34
      }
    },
    {
      "selector": "Dialog",
      "style": {
        "titleColor": "#F9FAFB",
        "textColor": "#D1D5DB",
        "bgColor": "#1F2937",
        "borderColor": "#374151",
        "buttonColor": "#374151",
        "buttonHoverColor": "#312E81",
        "buttonTextColor": "#818CF8"
      }
    },
    {
      "selector": "Text",
      "style": {
        "color": "#E5E7EB",
        "bgColor": "#1F2937",
        "fontSize": 13,
        "lineNumberBgColor": "#111827",
        "lineNumberColor": "#6B7280",
        "cursorColor": "#818CF8",
        "selectionColor": "#6366F144",
        "keyword": "#A5B4FC",
        "string": "#6EE7B7",
        "number": "#FCD34D",
        "comment": "#6B7280",
        "punctuation": "#9CA3AF"
      }
    },
    {
      "selector": "Table",
      "style": {
        "color": "#E5E7EB",
        "bgColor": "#1F2937",
        "headerBgColor": "#111827",
        "headerColor": "#9CA3AF",
        "gridLineColor": "#374151",
        "rowAltBgColor": "#18212F",
        "rowHoverColor": "#374151",
        "rowSelectedColor": "#312E81"
      }
    },
    {
      "selector": "Treeview",
      "style": {
        "color": "#E5E7EB",
        "bgColor": "#1F2937",
        "fontSize": 13,
        "selectedBgColor": "#312E81",
        "hoverBgColor": "#374151"
      }
    },
    {
      "selector": "Pagination",
      "style": {
        "color": "#9CA3AF",
        "buttonBgColor": "#374151",
        "buttonHoverColor": "#4B5563"
      }
    },
    {
      "selector": "Sash",
      "style": {
        "bgColor": "#374151",
        "hoverBgColor": "#4B5563",
        "borderColor": "#374151",
        "dotColor": "#6B7280",
        "hoverDotColor": "#9CA3AF",
        "accentColor": "#818CF8B3"
      }
    },
    {
      "selector": "Checkbox",
      "style": {
        "bgColor": "#1F2937",
        "borderColor": "#4B5563",
        "checkColor": "#818CF8"
      }
    },
    {
      "selector": "Checkbox.switch",
      "style": {
        "bgColor": "#374151",
        "borderColor": "#4B5563",
        "checkColor": "#818CF8"
      }
    },
    {
      "selector": "View.tabBar",
      "style": {
        "bgColor": "#1F2937",
        "borderBottomWidth": 1,
        "borderBottomColor": "#374151"
      }
    },
    {
      "selector": "Label.tab",
      "style": {
        "color": "#9CA3AF",
        "fontSize": 12,
        "padding": [6, 14, 6, 14],
        "borderRadius": 14,
        "bgColor": "transparent"
      }
    },
    {
      "selector": "Label.tab.active",
      "style": {
        "color": "#C7D2FE",
        "bgColor": "#312E81",
        "fontSize": 12,
        "padding": [6, 14, 6, 14],
        "borderRadius": 14
      }
    },
    { "selector": "Label.tabAdd", "style": { "color": "#6B7280", "fontSize": 14 } },
    {
      "selector": "View.settingsCard",
      "style": {
        "bgColor": "#1F2937",
        "borderRadius": 20
      }
    },
    {
      "selector": "#preferencesDialogFrame",
      "style": {
        "bgColor": "#374151",
        "borderRadius": 22
      }
    },
    {
      "selector": "Label.navItem",
      "style": {
        "color": "#9CA3AF",
        "fontSize": 12,
        "padding": [10, 14, 10, 14],
        "borderRadius": 14,
        "bgColor": "transparent"
      }
    },
    {
      "selector": "Label.navItem.active",
      "style": {
        "color": "#C7D2FE",
        "fontSize": 12,
        "padding": [10, 14, 10, 14],
        "borderRadius": 14,
        "bgColor": "#312E81"
      }
    },
    {
      "selector": "Label.sectionTitle",
      "style": {
        "color": "#9CA3AF",
        "fontSize": 11,
        "fontWeight": "bold"
      }
    }
  ]
}
