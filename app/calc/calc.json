                    "size": [
                        80,
                        80
                    ],
                    "events": {
                        "onClick": "@appendNumber",
                        "data": "5"
                    }
                },
                {
                    "id": "sixButton",
                    "type": "Button",
                    "text": "6",
                    "style": {
                        "color": "#FFFFFF",
                        "bgColor": "#333333",
                        "fontSize": 24,
                        "borderRadius": 8
                    },
                    "size": [
                        80,
                        80
                    ],
                    "events": {
                        "onClick": "@appendNumber",
