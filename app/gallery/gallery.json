              "text": "-- Soft UI gallery sample\nSELECT id, name FROM users\nWHERE active = 1\nORDER BY name;\n-- keyword / string / number themed"
            }
          ]
        },
        {
          "id": "secTable",
          "type": "View",
          "variant": "card",
          "size": [948, 260],
          "layout": { "type": "vertical", "spacing": 8, "padding": [14, 16, 14, 16] },
