{
    "id": "calculatorApp",
    "type": "View",
    "theme": "dark",
    "js": ["calc.js"],
    "style": {
        "color": "#FFFFFF",
        "bgColor": "#121212"
    },
    "size": [
        400,
        600
    ],
    "layout": {
        "type": "vertical",
        "spacing": 10,
        "padding": [
            20,
            20,
            20,
            20
        ]
    },
    "children": [
        {
            "id": "displayView",
            "type": "View",
            "size": [360, 110],
            "style": {
                "bgColor": "#1E1E1E",
                "borderRadius": 8
            },
            "layout": {
                "type": "vertical",
                "spacing": 5,
                "padding": [
                    10,
                    10,
                    10,
                    10
                ]
            },
            "children": [
                {
                    "id": "expressionDisplay",
                    "type": "Label",
                    "text": "",
                    "style": {
                        "color": "#AAAAAA",
                        "fontSize": 18,
                        "textAlign": "right"
                    },
                    "size": [
                        360,
                        30
                    ]
                },
                {
                    "id": "resultDisplay",
                    "type": "Label",
                    "text": "",
                    "style": {
                        "color": "#FFFFFF",
                        "fontSize": 36,
                        "fontWeight": "bold",
                        "textAlign": "right"
                    },
                    "size": [
                        360,
                        50
                    ]
                }
            ]
        },
        {
            "id": "buttonsView",
            "type": "Grid",
            "layout":{
                "columns": 4,
                "spacing": 6,
                "type": "vertical"
            },
