          "variant": "card",
          "size": [948, 130],
          "layout": { "type": "vertical", "spacing": 10, "padding": [14, 16, 14, 16] },
          "children": [
            { "type": "Label", "variant": "sectionTitle", "text": "Checkbox / Switch / Radiobox" },
            {
              "type": "View",
              "size": [900, 36],
              "layout": { "type": "horizontal", "spacing": 20, "align": "center" },
              "children": [
                { "id": "galleryCb1", "type": "Checkbox", "size": [20, 20], "data": true, "label": "勾选" },
                { "id": "galleryCb2", "type": "Checkbox", "size": [20, 20], "data": false, "label": "未勾选" },
                { "id": "gallerySwitch", "type": "Checkbox", "variant": "switch", "size": [40, 22], "data": true, "label": "自动" }
              ]
            },
            {
              "type": "View",
              "size": [900, 28],
              "layout": { "type": "horizontal", "spacing": 24, "align": "center" },
              "children": [
                { "id": "galleryRadio1", "type": "Radiobox", "size": [20, 20], "data": true, "label": "选项 A", "group": "galleryRadio" },
                { "id": "galleryRadio2", "type": "Radiobox", "size": [20, 20], "data": false, "label": "选项 B", "group": "galleryRadio" },
                { "id": "galleryRadio3", "type": "Radiobox", "size": [20, 20], "data": false, "label": "选项 C", "group": "galleryRadio" }
              ]
            }
          ]
        },
        {
          "id": "secSelectSlider",
