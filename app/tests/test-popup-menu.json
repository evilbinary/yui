{
    "id": "popupMenuTestApp",
    "type": "View",
    "theme": "default",
    "assets": "app/assets",
    "style": {
        "color": "#2C3E50",
        "bgColor": "#F5F5F5"
    },
    "layout": {
        "type": "vertical",
        "spacing": 20,
        "padding": [
            40,
            40,
            40,
            40
        ]
    },
    "children": [
        {
            "id": "title",
            "type": "Label",
            "text": "弹出菜单测试",
            "style": {
                "type": "center",
                "color": "#1976D2",
                "fontSize": 24,
                "marginBottom": 30
            }
        },
        {
            "id": "showMenuBtn",
            "type": "Button",
            "text": "显示右键菜单",
            "position": [50, 50],
            "size": [200, 40],
            "style": {
                "bgColor": "#2196F3",
                "textColor": "#FFFFFF",
                "hoverColor": "#1976D2",
                "radius": 6
            }
        },
        {
            "id": "showContextBtn",
            "type": "Button", 
            "text": "显示文件操作菜单",
            "position": [270, 50],
            "size": [200, 40],
            "style": {
                "bgColor": "#4CAF50",
                "textColor": "#FFFFFF", 
                "hoverColor": "#45a049",
                "radius": 6
            }
        },
        {
            "id": "resultLabel",
            "type": "Label",
            "text": "点击按钮或下方区域，验证 layerId:onClick 事件简写",
            "position": [50, 120],
            "size": [500, 30],
            "style": {
                "color": "#2C3E50",
                "fontSize": 16,
                "bgColor": "#E8F5E8",
                "radius": 4,
                "padding": [10, 5, 10, 5]
            }
        },
        {
            "id": "contextArea",
            "type": "View",
            "position": [50, 170],
            "size": [500, 300],
            "style": {
                "bgColor": "#FFFFFF",
                "borderColor": "#DDDDDD",
                "borderWidth": 1,
                "radius": 8
            }
        }
    ],
    "events": {
        "onLoad": "@initApp",
        "showMenuBtn:onClick": "@showContextMenu",
        "showContextBtn:onClick": "@showFileMenu",
        "contextArea:onClick": "@showAreaContextMenu",
        "initApp": "function() { YUI.log('popup-menu test loaded'); YUI.setText('resultLabel', 'loaded: click buttons to test'); }",
        "showContextMenu": "function() { YUI.log('showContextMenu'); YUI.setText('resultLabel', 'event: showContextMenu'); }",
        "showFileMenu": "function() { YUI.log('showFileMenu'); YUI.setText('resultLabel', 'event: showFileMenu'); }",
        "showAreaContextMenu": "function() { YUI.log('showAreaContextMenu'); YUI.setText('resultLabel', 'event: showAreaContextMenu'); }"
    }
}