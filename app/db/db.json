{
  "id": "dbEditor",
  "text": "DB",
  "type": "View",
  "size": [900, 600],
  "js": ["./db.js"],
  "events": {
    "onLoad": "@onLoad",
    "onResize": "@onWindowResize"
  },
  "icon": "app/db/icon.png",
  "layout": { "type": "absolute" },
  "style": {
    "titleBarBgColor": "#1E1E2E",
    "color": "#CDD6F4",
    "bgColor": "#1E1E2E"
  },
  "children": [
        {
          "id": "mainContent",
        "type": "View",
        "position": [0, 36],
            "layout": {
              "type": "horizontal",
              "spacing": 0,
              "padding": [0, 0, 0, 0]
            },
        "size": [900, 534],
        "style": {
          "bgColor": "#1E1E2E"
        },
        "children": [
          {
            "id": "dbListPanel",
            "type": "View",
            "size": [240, 534],
            "layout": {
              "type": "vertical",
              "spacing": 6,
              "padding": [8, 8, 8, 8]
            },
            "style": {
              "bgColor": "#181825",
              "borderRightWidth": 1,
              "borderRightColor": "#313244"
            },
            "children": [
              
              {
                "id": "dbListSearch",
                "type": "Input",
                "size": [224, 24],
                "text": "",
                "placeholder": "搜索表...",
                "style": {
                  "color": "#CDD6F4",
                  "bgColor": "#1E1E2E",
                  "fontSize": 11,
                  "padding": [6, 10, 6, 10]
                },
                "events": {
                  "onChange": "@onSearchDb"
                }
              },
              {
                "id": "dbTree",
                "type": "Treeview",
                "size": [224, 470],
                "flex": 1,
                "scrollable": 1,
                "style": {
                  "fontSize": 13
                },
                "events": {
                  "onSelect": "@onDbSelect",
                  "onExpand": "@onDbExpand"
                }
              }
            ]
          },
          {
            "id": "editorPanel",
            "type": "View",
            "flex": 1,
            "size": [0, 534],
            "layout": {
              "type": "vertical",
              "spacing": 0
            },
            "style": {
              "bgColor": "#1E1E2E"
            },
            "children": [
              {
                "id": "sqlEditorContainer",
                "type": "View",
                "size": [0, 352],
                "layout": {
                  "type": "vertical",
                  "spacing": 0
                },
                "style": {
                  "bgColor": "#11111B"
                },
                "children": [
                  {
                    "id": "sqlToolbar",
                    "type": "View",
                    "size": [0, 32],
                    "layout": {
                      "type": "horizontal",
                      "spacing": 4,
                      "padding": [6, 12, 6, 12],
                      "align": "center"
                    },
                    "style": {
                      "bgColor": "#181825",
                      "borderBottomWidth": 1,
                      "borderBottomColor": "#313244"
                    },
                    "children": [
                      {
                        "id": "btnRun",
                        "type": "Button",
                        "size": [48, 24],
                        "icon": "app/assets/icons/run.svg",
                        "text": "运行",
                        "style": {
                          "color": "#A6E3A1",
                          "bgColor": "#313244",
                          "borderRadius": 4,
                          "fontSize": 11
                        },
                        "events": { "onClick": "@executeQuery" }
                      },
                      {
                        "id": "btnExplain",
                        "type": "Button",
                        "size": [28, 22],
                        "icon": "app/assets/icons/btnExplain.svg",
                        "style": {
                          "color": "#F9E2AF",
                          "hoverColor": "#FCD34D",
                          "bgColor": "transparent",
                          "fontSize": 12,
                          "borderRadius": 3
                        },
                        "events": { "onClick": "@onExplain" }
                      },
                      {
                        "id": "btnFormat",
                        "type": "Button",
                        "size": [28, 22],
                        "icon": "app/assets/icons/btnFormat.svg",
                        "style": {
                          "color": "#89B4FA",
                          "hoverColor": "#B4D0FB",
                          "bgColor": "transparent",
                          "fontSize": 13,
                          "borderRadius": 3
                        },
                        "events": { "onClick": "@onFormat" }
                      },
                      {
                        "id": "btnSave",
                        "type": "Button",
                        "size": [28, 22],
                        "icon": "app/assets/icons/btnSave.svg",
                        "style": {
                          "color": "#A6ADC8",
                          "hoverColor": "#CDD6F4",
                          "bgColor": "transparent",
                          "fontSize": 12,
                          "borderRadius": 3
                        },
                        "events": { "onClick": "@onSave" }
                      },
                      {
                        "id": "btnOpen",
                        "type": "Button",
                        "size": [28, 22],
                        "icon": "app/assets/icons/btnOpen.svg",
                        "style": {
                          "color": "#A6ADC8",
                          "hoverColor": "#CDD6F4",
                          "bgColor": "transparent",
                          "fontSize": 12,
                          "borderRadius": 3
                        },
                        "events": { "onClick": "@onOpen" }
                      },
                      {
                        "id": "btnClear",
                        "type": "Button",
                        "size": [48, 24],
                        "text": "清空",
                        "style": {
                          "color": "#F38BA8",
                          "bgColor": "#313244",
                          "borderRadius": 4,
                          "fontSize": 11
                        },
                        "events": { "onClick": "@clearEditor" }
                      }
                    ]
                  },
                  {
                    "id": "sqlTabBar",
                    "type": "View",
                    "variant": "tabBar",
                    "size": [0, 28],
                    "layout": {
                      "type": "horizontal",
                      "spacing": 0,
                      "padding": [6, 12, 6, 12],
                      "align": "center"
                    },
                    "children": [
                      {
                        "id": "sqlTabs",
                        "type": "View",
                        "size": [0, 28],
                        "layout": {
                          "type": "horizontal",
                          "spacing": 0,
                          "align": "center"
                        },
                        "children": [
                          {
                            "id": "tab_0",
                            "type": "Label",
                            "variant": "tab active",
                            "text": "Query 1",
                            "events": { "onClick": "@onTabClick" }
                          },
                          {
                            "id": "tab_1",
                            "type": "Label",
                            "variant": "tab",
                            "text": "",
                            "visible": false,
                            "events": { "onClick": "@onTabClick" }
                          },
                          {
                            "id": "tab_2",
                            "type": "Label",
                            "variant": "tab",
                            "text": "",
                            "visible": false,
                            "events": { "onClick": "@onTabClick" }
                          },
                          {
                            "id": "tab_3",
                            "type": "Label",
                            "variant": "tab",
                            "text": "",
                            "visible": false,
                            "events": { "onClick": "@onTabClick" }
                          },
                          {
                            "id": "tab_4",
                            "type": "Label",
                            "variant": "tab",
                            "text": "",
                            "visible": false,
                            "events": { "onClick": "@onTabClick" }
                          }
                        ]
                      },
                      {
                        "id": "newTabBtn",
                        "type": "Label",
                        "variant": "tabAdd",
                        "size": [28, 22],
                        "text": "+",
                        "events": { "onClick": "@onNewTab" }
                      }
                    ]
                  },
                  {
                    "id": "sqlEditor",
                    "type": "Text",
                    "syntaxHighlight": "sql",
                    "text": "",
                    "flex": 1,
                    "multiline": true,
                    "editable": true,
                    "scrollable": 1,
                    "showLineNumbers": true,
                    "lineNumberWidth": 40,
                    "events": {
                      "onChange": "@onSqlChange"
                    },
                    "style": {
                      "fontSize": 13,
                      "padding": [12, 12, 12, 12]
                    }
                  }
                ]
              },
              {
                "id": "editorResultSash",
                "type": "Sash",
                "size": [0, 6],
                "target": "sqlEditorContainer",
                "minSize": 80,
                "events": {
                  "onChange": "@onEditorResultSashChange"
                }
              },
              {
                "id": "resultContainer",
                "type": "View",
                "size": [0, 176],
                "layout": {
                  "type": "vertical",
                  "spacing": 0
                },
                "style": {
                  "bgColor": "#11111B"
                },
                "children": [
                  {
                    "id": "resultTabBar",
                    "type": "View",
                    "size": [0, 32],
                    "layout": {
                      "type": "horizontal",
                      "spacing": 12,
                      "padding": [8, 12, 8, 12],
                      "align": "center"
                    },
                    "style": {
                      "bgColor": "#181825",
                      "borderBottomWidth": 1,
                      "borderBottomColor": "#313244"
                    },
                    "children": [
                      {
                        "id": "resultTab",
                        "type": "Label",
                        "size": [86, 24],
                        "text": "查询结果",
                        "textAlign": "left",
                        "style": {
                          "color": "#CDD6F4",
                          "fontSize": 12
                        }
                      },
                      {
                        "id": "resultInfo",
                        "type": "Label",
                        "size": [96, 24],
                        "text": "(0 行)",
                        "textAlign": "left",
                        "style": {
                          "color": "#6C7086",
                          "fontSize": 11
                        }
                      },
                      {
                        "id": "resultTabBarSpacer",
                        "type": "View",
                        "size": [0, 1],
                        "flex": 1
                      },
                      {
                        "id": "btnExportCsv",
                        "type": "Button",
                        "size": [72, 24],
                        "text": "导出CSV",
                        "style": {
                          "fontSize": 11,
                          "borderRadius": 4
                        },
                        "events": { "onClick": "@onExportCsv" }
                      },
                      {
                        "id": "resultPager",
                        "type": "Pagination",
                        "mode": "simple",
                        "size": [220, 28],
                        "page": 1,
                        "pageSize": 500,
                        "total": 0,
                        "hideOnSinglePage": false,
                        "showTotal": true,
                        "events": {
                          "onChange": "@onResultPageChange"
                        },
                        "style": {
                          "fontSize": 11,
                          "itemSize": 24
                        }
                      }
                    ]
                  },
                  {
                    "id": "resultTable",
                    "type": "Table",
                    "scrollable": 3,
                    "flex": 1,
                    "autoColumns": true,
                    "rowHeight": 28,
                    "headerHeight": 32,
                    "stripeRows": true,
                    "showGridLines": true,
                    "data": [],
                    "events": {
                      "onSelect": "@onResultRowClick"
                    },
                    "style": {
                      "fontSize": 13
                    }
                  }
                ]
              }
            ]
          }
      ]
    },
    {
      "id": "fileMenuPopup",
      "type": "Menu",
      "position": [0, 0],
      "size": [40, 204],
      "text": "文件",
      "fontSize": 12,
      "style": {
        "itemHeight": 29
      },
      "items": [
        { "text": "新建查询", "onClick": "@onNewTab" },
        { "text": "打开文件", "onClick": "@onOpen" },
        { "text": "保存文件", "onClick": "@onSave" },
        { "text": "导出 CSV", "onClick": "@onExportCsv" },
        { "separator": true },
        { "text": "退出", "onClick": "onExit" }
      ],
      "events": {
            "onSelect": "@handleMenuClick"
        }
    },
    {
      "id": "dbMenuPopup",
      "type": "Menu",
      "position": [80, 0],
      "size": [40, 175],
      "text": "数据库",
      "fontSize": 12,
      "style": {
        "itemHeight": 29
      },
      "items": [
        { "text": "新建连接", "onClick": "onNewConnection" },
        { "text": "连接数据库", "onClick": "connectDb" },
        { "text": "断开连接", "onClick": "disconnectDb" },
        { "separator": true },
        { "text": "导入数据库", "onClick": "onImportDb" }
      ],
      "events": {
            "onSelect": "@handleMenuClick"
        }
    },
    {
      "id": "settingsMenuPopup",
      "type": "Menu",
      "position": [164, 0],
      "size": [40, 88],
      "text": "设置",
      "fontSize": 12,
      "style": {
        "itemHeight": 29
      },
      "items": [
        { "text": "偏好设置", "onClick": "onOpenSettings" },
        { "separator": true },
        { "text": "关于", "onClick": "onAbout" }
      ],
      "events": {
            "onSelect": "@handleMenuClick"
        }
    },
    {
      "id": "statusBar",
      "type": "View",
      "position": [0, 570],
      "size": [900, 30],
      "layout": {
        "type": "horizontal",
        "spacing": 12,
        "padding": [8, 12, 8, 12],
        "align": "center"
      },
      "style": {
        "bgColor": "#181825",
        "borderTopWidth": 1,
        "borderTopColor": "#313244"
      },
      "children": [
        {
          "id": "statusIcon",
          "type": "Label",
          "size": [20, 20],
          "text": "●",
          "style": {
            "color": "#F38BA8",
            "fontSize": 10
          }
        },
        {
          "id": "statusText",
          "type": "Label",
          "text": "未连接",
          "size": [300, 20],
          "textAlign": "left",
          "style": {
            "color": "#CDD6F4",
            "fontSize": 11,
            "fontWeight": "bold"
          }
        }
      ]
    },
    {
      "id": "aboutDialog",
      "type": "Dialog",
      "title": "关于 YUI",
      "message": "YUI - Ya Ya User Interface\n\n一款面向 AI 应用的轻量级 GUI 框架，由 evilbinary 开发，使用 C 语言构建，通过 JSON 描述界面。\n\n主要特性：\n• 轻量高性能，支持脏矩形渲染\n• 声明式 JSON 配置 UI\n• 跨平台（Windows / macOS / Linux）\n• 丰富组件、动画系统、主题切换\n• 支持 QuickJS / mquickjs / Mario 引擎\n\n许可证：LGPL-2.1\n项目地址：github.com/evilbinary/YUI\n\nYUI DB Editor v0.1",
      "dialogType": "info",
      "modal": true,
      "fontSize": 12,
      "size": [360, 240],
      "buttons": [
        { "text": "确定", "default": true,
          "style": {
            "width": 72,
            "height": 28
          }}
      ]
    },
