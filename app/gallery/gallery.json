{
  "id": "galleryRoot",
  "type": "View",
  "variant": "surface",
  "size": [980, 720],
  "js": ["gallery.js"],
  "layout": { "type": "vertical", "spacing": 0 },
  "children": [
    {
      "id": "galleryToolbar",
      "type": "View",
      "variant": "toolbar",
      "size": [980, 156],
      "layout": { "type": "vertical", "spacing": 8, "padding": [12, 16, 12, 16] },
      "children": [
        {
          "id": "galleryTitleRow",
          "type": "View",
          "size": [948, 28],
          "layout": { "type": "horizontal", "spacing": 12, "align": "center" },
          "children": [
            { "id": "galleryTitle", "type": "Label", "variant": "heading", "text": "Component Gallery" },
            { "id": "galleryStatus", "type": "Label", "variant": "subtitle", "text": "加载主题中…" }
          ]
        },
        {
          "id": "galleryThemeRow1",
          "type": "View",
