{
    "id": "page_files",
    "title": "文件",
    "icon": "📁",
    "watchApp": { "id": "files", "order": 52 },
    "js": ["files.js"],
    "type": "View",
    "variant": "surface",
    "flex": 1,
    "scrollable": 1,
    "layout": { "type": "vertical", "spacing": 8, "padding": [4, 16, 12, 16] },
    "events": { "onLoad": "@onFilesLoad", "onShow": "@onFilesShow" },
    "children": [
        { "id": "files_brand", "type": "Label", "variant": "overline", "text": "FILES" },
        { "id": "files_title", "type": "Label", "variant": "title", "text": "文件管理" },
        { "id": "files_path", "type": "Label", "variant": "caption", "text": "app/watch-os/" },
        {
            "id": "files_actions",
            "type": "View",
            "size": [358, 36],
            "layout": { "type": "horizontal", "spacing": 8 },
            "children": [
                { "id": "btn_files_up", "type": "Button", "variant": "secondary", "text": "上级", "flex": 1, "size": [0, 36], "events": { "onClick": "@onFilesUp" } },
                { "id": "btn_files_refresh", "type": "Button", "variant": "primary", "text": "刷新", "flex": 1, "size": [0, 36], "events": { "onClick": "@refreshFilesList" } }
            ]
        },
        { "id": "files_status", "type": "Label", "variant": "subtitle", "text": "浏览手表文件" },
        {
            "id": "files_list",
            "type": "List",
            "width": 358,
            "flex": 1,
            "scrollable": 1,
            "data": [],
            "itemTemplate": {
                "type": "Button",
                "variant": "ghost",
                "icon": "${icon}",
                "text": "${name}",
                "iconSize": 16,
                "fontSize": 14,
                "style": { "color": "#E5E5EA", "bgColor": "transparent" },
                "size": [358, 36],
                "events": { "onClick": "@onFilesItemClick" }
            },
            "layout": { "type": "vertical", "spacing": 4 }
        }
    ]
}
