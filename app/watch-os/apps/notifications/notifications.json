            "type": "View",
            "variant": "list-row",
            "size": [358, 64],
            "layout": { "type": "vertical", "spacing": 4, "padding": [8, 12, 8, 12] },
            "children": [
                { "id": "notif_1_header", "type": "Label", "variant": "heading", "text": "快递 · 电话", "size": [334, 16] },
                { "id": "notif_1_body", "type": "Label", "variant": "body", "text": "未接来电", "size": [334, 14] },
                { "id": "notif_1_time", "type": "Label", "variant": "caption", "text": "14:20" }
            ]
        },
        {
            "id": "notif_row_2",
            "type": "View",
            "variant": "list-row",
