          "type": "Button",
          "text": "Layout 4列",
          "size": [100, 36],
          "style": { "bgColor": "#74c7ec", "color": "#1e1e2e", "fontSize": 12, "borderRadius": 4 },
          "events": { "onClick": "@setLayoutColumns4" }
