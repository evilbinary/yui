{
  "name": "light",
  "version": "1.0",
  "description": "通用亮色主题 - 组件类型 + 复合选择器 Type.modifier",
  "styles": [
    {
      "selector": "View",
      "style": { "bgColor": "#F5F6FA" }
    },
    {
      "selector": "Label",
      "style": { "color": "#1A1D26", "fontSize": 14 }
    },
    {
      "selector": "Button",
      "style": {
        "bgColor": "#FFFFFF",
        "color": "#1A1D26",
        "fontSize": 14,
        "borderRadius": 12
      }
    },
    {
      "selector": "Input",
      "style": {
        "bgColor": "#FFFFFF",
        "color": "#1A1D26",
        "fontSize": 14,
        "borderRadius": 10
      }
    },
    {
      "selector": "Image",
      "style": { "bgColor": "#FFFFFF", "borderRadius": 8 }
    },
    {
      "selector": "View.surface",
      "style": { "bgColor": "#F5F6FA" }
    },
    {
      "selector": "View.elevated",
      "style": { "bgColor": "#FFFFFF", "borderRadius": 16 }
    },
    {
      "selector": "View.toolbar",
      "style": { "bgColor": "#FFFFFF" }
    },
    {
      "selector": "View.card",
      "style": { "bgColor": "#FFFFFF", "borderRadius": 16 }
    },
    {
      "selector": "View.panel",
      "style": { "bgColor": "#F8F5FF", "borderRadius": 12 }
    },
    {
      "selector": "View.divider",
      "style": { "bgColor": "#E2E5EB" }
    },
    {
      "selector": "Label.title",
      "style": { "color": "#1A1D26", "fontSize": 22, "fontWeight": "bold" }
    },
    {
      "selector": "Label.heading",
      "style": { "color": "#1A1D26", "fontSize": 20, "fontWeight": "bold" }
    },
    {
      "selector": "Label.subtitle",
      "style": { "color": "#5C6578", "fontSize": 13 }
    },
    {
      "selector": "Label.body",
      "style": { "color": "#5C6578", "fontSize": 14 }
    },
    {
      "selector": "Label.caption",
      "style": { "color": "#8B95A8", "fontSize": 10 }
    },
    {
      "selector": "Label.overline",
      "style": { "color": "#8B95A8", "fontSize": 12, "fontWeight": "bold" }
    },
    {
      "selector": "Label.link",
      "style": { "color": "#6B5CE7", "fontSize": 12 }
    },
    {
      "selector": "Label.price",
      "style": { "color": "#C4860A", "fontSize": 20, "fontWeight": "bold" }
    },
    {
      "selector": "Label.badge",
      "style": { "color": "#6B5CE7", "fontSize": 11, "fontWeight": "bold" }
    },
    {
      "selector": "Button.primary",
      "style": {
        "bgColor": "#6B5CE7",
        "color": "#FFFFFF",
        "fontWeight": "bold",
        "borderRadius": 10
      }
    },
    {
      "selector": "Button.secondary",
      "style": {
        "bgColor": "#F0F2F5",
        "color": "#1A1D26",
        "borderRadius": 10
      }
    },
    {
      "selector": "Button.tertiary",
      "style": {
        "bgColor": "#EDE9FE",
        "color": "#6B5CE7",
        "borderRadius": 10
      }
    },
    {
      "selector": "Button.danger",
      "style": {
        "bgColor": "#F0F2F5",
        "color": "#E5484D",
        "borderRadius": 10
      }
    },
    {
      "selector": "Button.tone-a",
      "style": { "bgColor": "#F8F5FF", "color": "#6B5CE7", "fontWeight": "bold" }
    },
    {
      "selector": "Button.tone-b",
      "style": { "bgColor": "#FFF0F6", "color": "#D6408F", "fontWeight": "bold" }
    },
    {
      "selector": "Button.tone-c",
      "style": { "bgColor": "#EFF6FF", "color": "#2563EB", "fontWeight": "bold" }
    },
    {
      "selector": "Button.compact",
      "style": { "fontSize": 12, "borderRadius": 8 }
    },
    {
      "selector": "Button.block",
      "style": { "borderRadius": 10 }
    }
  ]
}
