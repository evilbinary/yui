{
  "name": "dark",
  "version": "1.0",
  "description": "通用暗色主题 - 组件类型 + 复合选择器 Type.modifier",
  "styles": [
    {
      "selector": "View",
      "style": { "bgColor": "#0A0D12" }
    },
    {
      "selector": "Label",
      "style": { "color": "#F2F4F8", "fontSize": 14 }
    },
    {
      "selector": "Button",
      "style": {
        "bgColor": "#1A2030",
        "color": "#F2F4F8",
        "fontSize": 14,
        "borderRadius": 12
      }
    },
    {
      "selector": "Input",
      "style": {
        "bgColor": "#1A2030",
        "color": "#F2F4F8",
        "fontSize": 14,
        "borderRadius": 10
      }
    },
    {
      "selector": "Image",
      "style": { "bgColor": "#12161E", "borderRadius": 8 }
    },
    {
      "selector": "View.surface",
      "style": { "bgColor": "#0A0D12" }
    },
    {
      "selector": "View.elevated",
      "style": { "bgColor": "#12161E", "borderRadius": 16 }
    },
    {
      "selector": "View.toolbar",
      "style": { "bgColor": "#12161E" }
    },
    {
      "selector": "View.card",
      "style": { "bgColor": "#1A2030", "borderRadius": 16 }
    },
    {
      "selector": "View.panel",
      "style": { "bgColor": "#1E2433", "borderRadius": 12 }
    },
    {
      "selector": "View.divider",
      "style": { "bgColor": "#2E3648" }
    },
    {
      "selector": "Label.title",
      "style": { "color": "#FFFFFF", "fontSize": 22, "fontWeight": "bold" }
    },
    {
      "selector": "Label.heading",
      "style": { "color": "#FFFFFF", "fontSize": 20, "fontWeight": "bold" }
    },
    {
      "selector": "Label.subtitle",
      "style": { "color": "#9AA3B2", "fontSize": 13 }
    },
    {
      "selector": "Label.body",
      "style": { "color": "#9AA3B2", "fontSize": 14 }
    },
    {
      "selector": "Label.caption",
      "style": { "color": "#6B7280", "fontSize": 10 }
    },
    {
      "selector": "Label.overline",
      "style": { "color": "#6B7280", "fontSize": 12, "fontWeight": "bold" }
    },
    {
      "selector": "Label.link",
      "style": { "color": "#7C6CFF", "fontSize": 12 }
    },
    {
      "selector": "Label.price",
      "style": { "color": "#E8C47C", "fontSize": 20, "fontWeight": "bold" }
    },
    {
      "selector": "Label.badge",
      "style": { "color": "#7C6CFF", "fontSize": 11, "fontWeight": "bold" }
    },
    {
      "selector": "Button.primary",
      "style": {
        "bgColor": "#7C6CFF",
        "color": "#FFFFFF",
        "fontWeight": "bold",
        "borderRadius": 10
      }
    },
    {
      "selector": "Button.secondary",
      "style": {
        "bgColor": "#1A2030",
        "color": "#F2F4F8",
        "borderRadius": 10
      }
    },
    {
      "selector": "Button.tertiary",
      "style": {
        "bgColor": "#1E2433",
        "color": "#C5CDDB",
        "borderRadius": 10
      }
    },
    {
      "selector": "Button.danger",
      "style": {
        "bgColor": "#1A2030",
        "color": "#EF5B5B",
        "borderRadius": 10
      }
    },
    {
      "selector": "Button.tone-a",
      "style": { "bgColor": "#1E2433", "color": "#E8E4FF", "fontWeight": "bold" }
    },
    {
      "selector": "Button.tone-b",
      "style": { "bgColor": "#1E2433", "color": "#FFE8F0", "fontWeight": "bold" }
    },
    {
      "selector": "Button.tone-c",
      "style": { "bgColor": "#1E2433", "color": "#E8F4FF", "fontWeight": "bold" }
    },
    {
      "selector": "Button.compact",
      "style": { "fontSize": 12, "borderRadius": 8 }
    },
    {
      "selector": "Button.block",
      "style": { "borderRadius": 10 }
    }
  ]
}
