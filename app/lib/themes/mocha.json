{
  "name": "mocha",
  "version": "1.0",
  "description": "Catppuccin Mocha",
  "styles": [
    { "selector": "View", "style": { "bgColor": "#1E1E2E" } },
    { "selector": "Label", "style": { "color": "#CDD6F4", "fontSize": 12 } },
    { "selector": "Button", "style": { "bgColor": "#313244", "color": "#CDD6F4", "borderRadius": 4, "fontSize": 12 } },
    { "selector": "Button.primary", "style": { "bgColor": "#89B4FA", "color": "#1E1E2E", "borderRadius": 4, "fontWeight": "bold" } },
    { "selector": "Button.secondary", "style": { "bgColor": "#45475A", "color": "#CDD6F4", "borderRadius": 4 } },
    { "selector": "Button.tertiary", "style": { "bgColor": "#313244", "color": "#89B4FA", "borderRadius": 4 } },
    { "selector": "Button.danger", "style": { "bgColor": "#313244", "color": "#F38BA8", "borderRadius": 4 } },
    { "selector": "Button.compact", "style": { "fontSize": 12, "borderRadius": 4 } },
    { "selector": "Input", "style": { "bgColor": "#1E1E2E", "color": "#CDD6F4", "fontSize": 12, "borderColor": "#45475A", "focusBorderColor": "#89B4FA" } },
    { "selector": "Text", "style": { "color": "#CDD6F4", "bgColor": "#11111B", "fontSize": 13, "lineNumberBgColor": "#181825", "lineNumberColor": "#6C7086", "cursorColor": "#89B4FA", "selectionColor": "#45475A99", "keyword": "#CBA6F7", "string": "#A6E3A1", "number": "#FAB387", "comment": "#6C7086", "punctuation": "#89DCEB" } },
    { "selector": "Table", "style": { "color": "#CDD6F4", "bgColor": "#11111B", "headerBgColor": "#181825", "headerColor": "#A6ADC8", "gridLineColor": "#313244", "rowAltBgColor": "#1a1a24", "rowHoverColor": "#313244", "rowSelectedColor": "#45475A", "scrollbarColor": "#585B70", "scrollbarTrackColor": "#11111B80" } },
    { "selector": "Treeview", "style": { "color": "#CDD6F4", "bgColor": "#181825", "fontSize": 13, "selectedBgColor": "#45475A", "hoverBgColor": "#313244", "scrollbarColor": "#585B70", "scrollbarTrackColor": "#18182580" } },
    { "selector": "Pagination", "style": { "color": "#A6ADC8", "buttonBgColor": "#313244", "buttonHoverColor": "#45475A" } },
    { "selector": "Sash", "style": { "bgColor": "#313244", "hoverBgColor": "#45475A", "borderColor": "#45475A", "dotColor": "#6C7086", "hoverDotColor": "#A6ADC8", "accentColor": "#89B4FAB3" } },
    { "selector": "Checkbox", "style": { "bgColor": "#11111B", "borderColor": "#585B70", "checkColor": "#A6E3A1" } },
    { "selector": "Checkbox.switch", "style": { "bgColor": "#313244", "borderColor": "#45475A", "checkColor": "#A6E3A1" } },
    { "selector": "Menu", "style": { "bgColor": "#1E1E2E", "textColor": "#CDD6F4", "hoverColor": "#45475A", "disabledColor": "#6C7086", "separatorColor": "#585B70", "itemHeight": 29 } },
    { "selector": "Dialog", "style": { "titleColor": "#89B4FA", "textColor": "#CDD6F4", "bgColor": "#1E1E2E", "borderColor": "#45475A", "buttonColor": "#313244", "buttonHoverColor": "#45475A", "buttonTextColor": "#CDD6F4" } },
    { "selector": "View.tabBar", "style": { "bgColor": "#11111B", "borderBottomWidth": 1, "borderBottomColor": "#313244" } },
    { "selector": "Label.tab", "style": { "color": "#6C7086", "fontSize": 11, "padding": [4, 10, 4, 10], "borderRadius": 4, "bgColor": "transparent" } },
    { "selector": "Label.tab.active", "style": { "color": "#CDD6F4", "bgColor": "#1E1E2E", "fontSize": 11, "padding": [4, 10, 4, 10], "borderRadius": 4 } },
    { "selector": "Label.tabAdd", "style": { "color": "#6C7086", "fontSize": 14 } },
    { "selector": "View.settingsCard", "style": { "bgColor": "#181825", "borderRadius": 8 } },
    { "selector": "#preferencesDialogFrame", "style": { "bgColor": "#45475A", "borderRadius": 9 } },
    { "selector": "Label.navItem", "style": { "color": "#A6ADC8", "fontSize": 12, "padding": [8, 12, 8, 12], "borderRadius": 6, "bgColor": "transparent" } },
    { "selector": "Label.navItem.active", "style": { "color": "#CDD6F4", "fontSize": 12, "padding": [8, 12, 8, 12], "borderRadius": 6, "bgColor": "#313244" } },
    { "selector": "Label.sectionTitle", "style": { "color": "#A6ADC8", "fontSize": 11, "fontWeight": "bold" } }
  ]
}
