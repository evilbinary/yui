{
    "id": "lifecycle_app",
    "type": "View",
    "size": [640, 420],
    "text": "Page Lifecycle Test",
    "js": "test-page-lifecycle.js",
    "style": {
        "bgColor": "#1E1E2E",
        "color": "#CDD6F4"
    },
    "layout": {
        "type": "vertical",
        "spacing": 6,
        "padding": [8, 8, 8, 8]
    },
    "events": {
        "onLoad": "@onAppLoad"
    },
    "children": [
        {
            "id": "nav",
            "type": "View",
            "size": [624, 40],
            "style": {
                "bgColor": "#313244"
            },
            "layout": {
                "type": "horizontal",
                "spacing": 6,
                "padding": [4, 4, 4, 4]
            },
            "children": [
                {
                    "id": "btn_home",
                    "type": "Button",
                    "text": "Home",
                    "events": { "onClick": "@goHome" }
                },
                {
                    "id": "btn_list",
                    "type": "Button",
                    "text": "List",
                    "events": { "onClick": "@goList" }
                },
                {
                    "id": "btn_detail",
                    "type": "Button",
                    "text": "Detail",
                    "events": { "onClick": "@goDetail" }
                },
                {
                    "id": "btn_destroy",
                    "type": "Button",
                    "text": "Destroy List",
                    "events": { "onClick": "@destroyListPage" }
                }
            ]
        },
        {
            "id": "page_outlet",
            "type": "View",
            "flex": 1,
            "style": {
                "bgColor": "#181825"
            },
            "layout": {
                "type": "vertical"
            },
            "children": [
                {
                    "id": "page_home",
                    "type": "View",
                    "flex": 1,
                    "visible": true,
                    "style": {
                        "bgColor": "#45475A"
                    },
                    "events": {
                        "onLoad": "@onHomeLoad",
                        "onShow": "@onHomeShow",
                        "onHide": "@onHomeHide",
                        "onUnload": "@onHomeUnload"
                    },
                    "children": [
                        {
                            "id": "home_label",
                            "type": "Label",
                            "text": "Home Page",
                            "style": { "color": "#CDD6F4", "fontSize": 20 }
                        }
                    ]
                }
            ]
        },
        {
            "id": "log",
            "type": "Label",
            "size": [624, 100],
            "text": "log:",
            "style": { "color": "#BAC2DE", "fontSize": 12 }
        }
    ]
}
