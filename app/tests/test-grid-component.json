{
  "id": "gridTestApp",
  "type": "View",
  "size": [560, 560],
  "js": "test-grid-component.js",
  "style": {
    "bgColor": "#1e1e2e"
  },
  "layout": {
    "type": "vertical",
    "spacing": 12,
    "padding": [16, 16, 16, 16]
  },
  "children": [
    {
      "id": "title",
      "type": "Label",
      "text": "Grid 组件 / layout.grid 测试",
      "size": [528, 32],
      "style": {
        "color": "#cdd6f4",
        "fontSize": 20
      }
    },
    {
      "id": "statusLabel",
      "type": "Label",
      "text": "状态：就绪（点击格子或下方按钮）",
      "size": [528, 22],
      "style": {
        "color": "#a6adc8",
        "fontSize": 13
      }
    },
    {
      "id": "sectionA",
      "type": "Label",
      "text": "A. type=Grid，顶层 columns: 3",
      "size": [528, 20],
      "style": {
        "color": "#89b4fa",
        "fontSize": 13
      }
    },
    {
      "id": "gridComponent",
      "type": "Grid",
      "columns": 3,
      "gap": 6,
      "size": [528, 132],
      "style": {
        "bgColor": "#313244",
        "borderRadius": 6
      },
      "children": [
        {
          "id": "g1",
          "type": "Button",
          "text": "1",
          "style": { "bgColor": "#45475a", "color": "#cdd6f4", "fontSize": 14, "borderRadius": 4 },
          "events": { "onClick": "@onCellClick" }
        },
        {
          "id": "g2",
          "type": "Button",
          "text": "2",
          "style": { "bgColor": "#45475a", "color": "#cdd6f4", "fontSize": 14, "borderRadius": 4 },
          "events": { "onClick": "@onCellClick" }
        },
        {
          "id": "g3",
          "type": "Button",
          "text": "3",
          "style": { "bgColor": "#45475a", "color": "#cdd6f4", "fontSize": 14, "borderRadius": 4 },
          "events": { "onClick": "@onCellClick" }
        },
        {
          "id": "g4",
          "type": "Button",
          "text": "4",
          "style": { "bgColor": "#585b70", "color": "#cdd6f4", "fontSize": 14, "borderRadius": 4 },
