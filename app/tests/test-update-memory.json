            "style": {
                "color": "#89b4fa",
                "fontSize": 12,
                "fontFamily": "monospace"
            }
        },
        {
            "id": "btnRow1",
            "type": "View",
            "size": [0, 36],
            "layout": {
                "type": "horizontal",
                "spacing": 8
            },
            "children": [
                {
                    "id": "seq50Btn",
                    "type": "Button",
                    "text": "顺序×50",
                    "size": [100, 32],
                    "style": {
                        "bgColor": "#89b4fa",
                        "color": "#1e1e2e",
                        "fontSize": 12,
                        "borderRadius": 4
                    },
                    "events": { "onClick": "@stressSequential50" }
                },
                {
                    "id": "seq200Btn",
                    "type": "Button",
                    "text": "顺序×200",
