{
    "id": "page_files",
    "title": "文件",
    "icon": "📁",
    "watchApp": { "id": "files", "order": 52 },
    "js": ["files.js"],
    "type": "View",
    "variant": "surface",
    "flex": 1,
    "layout": { "type": "vertical", "spacing": 4, "padding": [2, 14, 4, 14] },
    "events": { "onLoad": "@onFilesLoad", "onShow": "@onFilesShow" },
    "children": [
        {
            "id": "files_toolbar",
            "type": "View",
            "size": [362, 18],
            "layout": { "type": "horizontal", "spacing": 4, "align": "center" },
            "children": [
                { "id": "files_path", "type": "Label", "variant": "caption", "text": "app/watch-os/", "flex": 1, "size": [0, 14], "textAlign": "left" },
                { "id": "files_status", "type": "Label", "variant": "caption", "text": "0 项", "size": [36, 14], "textAlign": "right" }
            ]
        },
        {
            "id": "files_actions",
            "type": "View",
            "size": [362, 22],
            "layout": { "type": "horizontal", "spacing": 6 },
            "children": [
                { "id": "btn_files_up", "type": "Button", "variants": ["tertiary", "compact"], "text": "上级", "size": [70, 22], "events": { "onClick": "@onFilesUp" } },
                { "id": "btn_files_refresh", "type": "Button", "variants": ["tertiary", "compact"], "text": "刷新", "size": [70, 22], "events": { "onClick": "@refreshFilesList" } }
            ]
        },
        {
            "id": "files_list",
            "type": "List",
            "flex": 1,
            "scrollable": 1,
            "data": [],
            "itemTemplate": {
                "type": "Button",
                "variant": "ghost",
                "icon": "${icon}",
                "text": "${name}",
                "iconSize": 14,
                "fontSize": 12,
                "style": { "color": "#E5E5EA", "bgColor": "transparent" },
                "size": [362, 28],
                "events": { "onClick": "@onFilesItemClick" }
            },
            "layout": { "type": "vertical", "spacing": 2 }
        }
    ]
}
