              "type": "View",
              "size": [900, 28],
              "layout": { "type": "horizontal", "spacing": 16, "align": "center" },
              "children": [
                { "type": "Label", "variant": "body", "size": [120, 24], "text": "Body 正文" },
                { "type": "Label", "variant": "subtitle", "size": [140, 24], "text": "Subtitle 说明" },
                { "type": "Label", "variant": "caption", "size": [120, 20], "text": "Caption 小字" },
                { "type": "Label", "variant": "link", "size": [100, 24], "text": "Link 链接" }
