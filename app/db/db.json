                { "id": "connectionDialogTitle", "type": "Label", "size": [400, 24], "text": "新建连接", "style": { "color": "#CDD6F4", "fontSize": 14, "fontWeight": "bold" } },
                { "id": "connectionDialogCloseBtn", "type": "Button", "size": [28, 28], "text": "×", "style": { "color": "#A6ADC8", "bgColor": "transparent", "fontSize": 16 }, "events": { "onClick": "@onConnectionCancel" } }
