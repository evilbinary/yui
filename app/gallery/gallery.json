                { "id": "btnPrimary", "type": "Button", "variant": "primary", "size": [120, 36], "text": "Primary", "events": { "onClick": "@onGalleryLog" } },
                { "id": "btnSecondary", "type": "Button", "variant": "secondary", "size": [120, 36], "text": "Secondary", "events": { "onClick": "@onGalleryLog" } },
                { "id": "btnTertiary", "type": "Button", "variant": "tertiary", "size": [120, 36], "text": "Tertiary", "events": { "onClick": "@onGalleryLog" } },
                { "id": "btnDanger", "type": "Button", "variant": "danger", "size": [120, 36], "text": "Danger", "events": { "onClick": "@onGalleryLog" } },
                { "id": "btnDefault", "type": "Button", "size": [120, 36], "text": "Default", "events": { "onClick": "@onGalleryLog" } }
              ]
            }
          ]
        },
        {
          "id": "secInputs",
          "type": "View",
          "variant": "card",
          "size": [948, 110],
          "layout": { "type": "vertical", "spacing": 10, "padding": [14, 16, 14, 16] },
          "children": [
            { "type": "Label", "variant": "sectionTitle", "text": "Input" },
