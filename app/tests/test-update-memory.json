                {
                    "id": "refreshPerfBtn",
                    "type": "Button",
                    "text": "刷新统计",
                    "size": [88, 32],
                    "style": {
                        "bgColor": "#45475a",
                        "color": "#cdd6f4",
                        "fontSize": 12,
                        "borderRadius": 4
                    },
                    "events": { "onClick": "@refreshPerfStats" }
