                    "size": [88, 32],
                    "style": {
                        "bgColor": "#89b4fa",
                        "color": "#1e1e2e",
                        "fontSize": 12,
                        "borderRadius": 4
                    },
                    "events": { "onClick": "@togglePerfOverlay" }
