{
  "name": "element-plus",
  "version": "1.0",
  "description": "Vue3 Element Plus 亮色主题 - 组件类型 + 复合选择器 Type.modifier",
  "styles": [
    {
      "selector": "View",
      "style": { "bgColor": "#F2F3F5" }
    },
    {
      "selector": "Label",
      "style": { "color": "#303133", "fontSize": 14 }
    },
    {
      "selector": "Button",
      "style": {
        "bgColor": "#FFFFFF",
        "color": "#606266",
        "fontSize": 14,
        "borderRadius": 4
      }
    },
    {
      "selector": "Input",
      "style": {
        "bgColor": "#FFFFFF",
        "color": "#606266",
        "fontSize": 14,
        "borderRadius": 4,
        "borderColor": "#DCDFE6",
        "focusBorderColor": "#409EFF"
      }
    },
    {
      "selector": "Image",
      "style": { "bgColor": "#FFFFFF", "borderRadius": 4 }
    },
    {
      "selector": "View.surface",
      "style": { "bgColor": "#F2F3F5" }
    },
    {
      "selector": "View.elevated",
      "style": { "bgColor": "#FFFFFF", "borderRadius": 4 }
    },
    {
      "selector": "View.toolbar",
      "style": { "bgColor": "#FFFFFF" }
    },
    {
      "selector": "View.card",
      "style": {
        "bgColor": "#FFFFFF",
        "borderRadius": 4,
        "borderWidth": 1,
        "borderColor": "#E4E7ED"
      }
    },
    {
      "selector": "View.panel",
      "style": { "bgColor": "#ECF5FF", "borderRadius": 4 }
    },
    {
      "selector": "View.divider",
      "style": { "bgColor": "#EBEEF5" }
    },
    {
      "selector": "Label.title",
      "style": { "color": "#303133", "fontSize": 22, "fontWeight": "bold" }
    },
    {
      "selector": "Label.heading",
      "style": { "color": "#303133", "fontSize": 20, "fontWeight": "bold" }
    },
    {
      "selector": "Label.subtitle",
      "style": { "color": "#909399", "fontSize": 13 }
    },
    {
      "selector": "Label.body",
      "style": { "color": "#606266", "fontSize": 14 }
    },
    {
      "selector": "Label.caption",
      "style": { "color": "#A8ABB2", "fontSize": 12 }
    },
    {
      "selector": "Label.overline",
      "style": { "color": "#909399", "fontSize": 12, "fontWeight": "bold" }
    },
    {
      "selector": "Label.link",
      "style": { "color": "#409EFF", "fontSize": 12 }
    },
    {
      "selector": "Label.price",
      "style": { "color": "#E6A23C", "fontSize": 20, "fontWeight": "bold" }
    },
    {
      "selector": "Label.badge",
      "style": { "color": "#409EFF", "fontSize": 11, "fontWeight": "bold" }
    },
    {
      "selector": "Button.primary",
      "style": {
        "bgColor": "#409EFF",
        "color": "#FFFFFF",
        "fontWeight": "bold",
        "borderRadius": 4
      }
    },
    {
      "selector": "Button.secondary",
      "style": {
        "bgColor": "#F5F7FA",
        "color": "#606266",
        "borderRadius": 4
      }
    },
    {
      "selector": "Button.tertiary",
      "style": {
        "bgColor": "#ECF5FF",
        "color": "#409EFF",
        "borderRadius": 4
      }
    },
    {
      "selector": "Button.danger",
      "style": {
        "bgColor": "#FEF0F0",
        "color": "#F56C6C",
        "borderRadius": 4
      }
    },
    {
      "selector": "Button.tone-a",
      "style": { "bgColor": "#ECF5FF", "color": "#409EFF", "fontWeight": "bold" }
    },
    {
      "selector": "Button.tone-b",
      "style": { "bgColor": "#F0F9EB", "color": "#67C23A", "fontWeight": "bold" }
    },
    {
      "selector": "Button.tone-c",
      "style": { "bgColor": "#FDF6EC", "color": "#E6A23C", "fontWeight": "bold" }
    },
    {
      "selector": "Button.compact",
      "style": { "fontSize": 12, "borderRadius": 4 }
    },
    {
      "selector": "Button.block",
      "style": { "borderRadius": 4 }
    },
    {
      "selector": "Menu",
      "style": {
        "bgColor": "#FFFFFF",
        "textColor": "#303133",
        "hoverColor": "#ECF5FF",
        "disabledColor": "#C0C4CC",
        "separatorColor": "#EBEEF5",
        "itemHeight": 34
      }
    },
    {
      "selector": "Dialog",
      "style": {
        "titleColor": "#303133",
        "textColor": "#606266",
        "bgColor": "#FFFFFF",
        "borderColor": "#E4E7ED",
        "buttonColor": "#FFFFFF",
        "buttonHoverColor": "#ECF5FF",
        "buttonTextColor": "#409EFF"
      }
    },
    {
      "selector": "Text",
      "style": {
        "color": "#303133",
        "bgColor": "#FFFFFF",
        "fontSize": 13,
        "lineNumberBgColor": "#F5F7FA",
        "lineNumberColor": "#909399",
        "cursorColor": "#409EFF",
        "selectionColor": "#409EFF33",
        "keyword": "#409EFF",
        "string": "#67C23A",
        "number": "#E6A23C",
        "comment": "#909399",
        "punctuation": "#606266"
      }
    },
    {
      "selector": "Table",
      "style": {
        "color": "#606266",
        "bgColor": "#FFFFFF",
        "headerBgColor": "#F5F7FA",
        "headerColor": "#909399",
        "gridLineColor": "#EBEEF5",
        "rowAltBgColor": "#FAFAFA",
        "rowHoverColor": "#F5F7FA",
        "rowSelectedColor": "#ECF5FF"
      }
    },
    {
      "selector": "Treeview",
      "style": {
        "color": "#606266",
        "bgColor": "#FFFFFF",
        "fontSize": 13,
        "selectedBgColor": "#ECF5FF",
        "hoverBgColor": "#F5F7FA"
      }
    },
    {
      "selector": "Pagination",
      "style": {
        "color": "#606266",
        "buttonBgColor": "#F5F7FA",
        "buttonHoverColor": "#E4E7ED"
      }
    },
    {
      "selector": "Sash",
      "style": {
        "bgColor": "#E4E7ED",
        "hoverBgColor": "#DCDFE6",
        "borderColor": "#DCDFE6",
        "dotColor": "#C0C4CC",
        "hoverDotColor": "#909399",
        "accentColor": "#409EFFB3"
      }
    },
    {
      "selector": "Checkbox",
      "style": {
        "bgColor": "#FFFFFF",
        "borderColor": "#DCDFE6",
        "checkColor": "#409EFF"
      }
    },
    {
      "selector": "Checkbox.switch",
      "style": {
        "bgColor": "#DCDFE6",
        "borderColor": "#DCDFE6",
        "checkColor": "#409EFF"
      }
    },
    {
      "selector": "View.tabBar",
      "style": {
        "bgColor": "#FFFFFF",
        "borderBottomWidth": 1,
        "borderBottomColor": "#E4E7ED"
      }
    },
    {
      "selector": "Label.tab",
      "style": {
        "color": "#303133",
        "fontSize": 12,
        "padding": [4, 16, 4, 16],
        "borderRadius": 0,
        "bgColor": "transparent"
      }
    },
    {
      "selector": "Label.tab.active",
      "style": {
        "color": "#409EFF",
        "bgColor": "transparent",
        "fontSize": 12,
        "padding": [4, 16, 4, 16],
        "borderRadius": 0
      }
    },
    {
      "selector": "Label.tabAdd",
      "style": {
        "color": "#909399",
        "fontSize": 14
      }
    },
    {
      "selector": "View.settingsCard",
      "style": {
        "bgColor": "#FFFFFF",
        "borderRadius": 4,
        "borderWidth": 1,
        "borderColor": "#E4E7ED"
      }
    },
    {
      "selector": "#preferencesDialogFrame",
      "style": {
        "bgColor": "#DCDFE6",
        "borderRadius": 5
      }
    },
    {
      "selector": "Label.navItem",
      "style": {
        "color": "#606266",
        "fontSize": 12,
        "padding": [8, 12, 8, 12],
        "borderRadius": 4,
        "bgColor": "transparent"
      }
    },
    {
      "selector": "Label.navItem.active",
      "style": {
        "color": "#409EFF",
        "fontSize": 12,
        "padding": [8, 12, 8, 12],
        "borderRadius": 4,
        "bgColor": "#ECF5FF"
      }
    },
    {
      "selector": "Label.sectionTitle",
      "style": {
        "color": "#909399",
        "fontSize": 11,
        "fontWeight": "bold"
      }
    }
  ]
}
