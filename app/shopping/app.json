{
    "id": "shopping_app",
    "type": "View",
    "size": [390, 844],
    "text": "优物商城",
    "js": [
        "../lib/router.js",
        "app.js",
        "page/home.js",
        "page/category.js",
        "page/product.js",
        "page/cart.js",
        "page/login.js"
    ],
    "style": {
        "bgColor": "#0A0D12",
        "color": "#F2F4F8"
    },
    "layout": {
        "type": "vertical",
        "spacing": 0,
        "padding": [0, 0, 0, 0]
    },
    "events": {
        "onLoad": "@onAppLoad",
        "onShow": "@onAppShow"
    },
    "children": [
        {
            "id": "header",
            "type": "View",
            "size": [390, 56],
            "style": {
                "bgColor": "#12161E",
                "borderColor": "#252B3A",
                "borderWidth": 1
            },
            "layout": {
                "type": "horizontal",
                "spacing": 8,
                "padding": [10, 14, 10, 14]
            },
            "children": [
                {
                    "id": "btn_back",
                    "type": "Button",
                    "text": "返回",
                    "size": [52, 36],
                    "events": { "onClick": "@goBack" },
                    "style": {
                        "bgColor": "#1A2030",
                        "color": "#C5CDDB",
                        "fontSize": 13,
                        "borderRadius": 10,
                        "borderColor": "#2E3648",
                        "borderWidth": 1
                    }
                },
                {
                    "id": "btn_logo",
                    "type": "Button",
                    "text": "优物",
                    "flex": 1,
                    "size": [0, 36],
                    "events": { "onClick": "@goHome" },
                    "style": {
                        "bgColor": "#7C6CFF",
                        "color": "#FFFFFF",
                        "fontSize": 15,
                        "fontWeight": "bold",
                        "borderRadius": 10
                    }
                },
                {
                    "id": "btn_cart",
                    "type": "Button",
                    "text": "袋·0",
                    "size": [56, 36],
                    "events": { "onClick": "@goCart" },
                    "style": {
                        "bgColor": "#1A2030",
                        "color": "#F2F4F8",
                        "fontSize": 13,
                        "fontWeight": "bold",
                        "borderRadius": 10,
                        "borderColor": "#2E3648",
                        "borderWidth": 1
                    }
                },
                {
                    "id": "btn_login",
                    "type": "Button",
                    "text": "登录",
                    "size": [52, 36],
                    "events": { "onClick": "@goLogin" },
                    "style": {
                        "bgColor": "#7C6CFF",
                        "color": "#FFFFFF",
                        "fontSize": 13,
                        "fontWeight": "bold",
                        "borderRadius": 10
                    }
                }
            ]
        },
        {
            "id": "page_outlet",
            "type": "View",
            "flex": 1,
            "style": { "bgColor": "#0A0D12" },
            "layout": { "type": "vertical" },
            "children": [
                {
                    "id": "page_home",
                    "type": "View",
                    "flex": 1,
                    "visible": false,
                    "scrollable": 1,
                    "style": { "bgColor": "#0A0D12" },
                    "layout": { "type": "vertical", "spacing": 12, "padding": [12, 16, 16, 16] },
                    "events": { "onLoad": "@onHomeLoad", "onShow": "@onHomeShow" },
                    "children": [
                        {
                            "id": "home_hero",
                            "type": "View",
                            "size": [358, 96],
                            "style": {
                                "bgColor": "#1A2030",
                                "borderRadius": 16,
                                "borderColor": "#2E3648",
                                "borderWidth": 1
                            },
                            "layout": { "type": "vertical", "spacing": 6, "padding": [18, 18, 18, 18] },
                            "children": [
                                {
                                    "id": "home_title",
                                    "type": "Label",
                                    "text": "发现精品好物",
                                    "style": { "color": "#FFFFFF", "fontSize": 22, "fontWeight": "bold" }
                                },
                                {
                                    "id": "home_subtitle",
                                    "type": "Label",
                                    "text": "精选数码、服饰与图书，品质生活从这里开始",
                                    "style": { "color": "#9AA3B2", "fontSize": 13 }
                                }
                            ]
                        },
                        {
                            "id": "home_cat_label",
                            "type": "Label",
                            "text": "商品分类",
                            "style": { "color": "#6B7280", "fontSize": 12, "fontWeight": "bold" }
                        },
                        {
                            "id": "btn_cat_electronics",
                            "type": "Button",
                            "text": "数码电器",
                            "size": [358, 44],
                            "events": { "onClick": "@homeGoElectronics" },
                            "style": {
                                "bgColor": "#1E2433",
                                "color": "#E8E4FF",
                                "fontSize": 14,
                                "fontWeight": "bold",
                                "borderRadius": 12,
                                "borderColor": "#7C6CFF",
                                "borderWidth": 1
                            }
                        },
                        {
                            "id": "btn_cat_fashion",
                            "type": "Button",
                            "text": "时尚服饰",
                            "size": [358, 44],
                            "events": { "onClick": "@homeGoFashion" },
                            "style": {
                                "bgColor": "#1E2433",
                                "color": "#FFE8F0",
                                "fontSize": 14,
                                "fontWeight": "bold",
                                "borderRadius": 12,
                                "borderColor": "#E879A9",
                                "borderWidth": 1
                            }
                        },
                        {
                            "id": "btn_cat_books",
                            "type": "Button",
                            "text": "图书文具",
                            "size": [358, 44],
                            "events": { "onClick": "@homeGoBooks" },
                            "style": {
                                "bgColor": "#1E2433",
                                "color": "#E8F4FF",
                                "fontSize": 14,
                                "fontWeight": "bold",
                                "borderRadius": 12,
                                "borderColor": "#5B8DEF",
                                "borderWidth": 1
                            }
                        },
                        {
                            "id": "home_feat_label",
                            "type": "Label",
                            "text": "为你推荐",
                            "style": { "color": "#6B7280", "fontSize": 12, "fontWeight": "bold" }
                        },
                        {
                            "id": "home_feat_info",
                            "type": "Label",
                            "text": "本周热销精选",
                            "style": { "color": "#9AA3B2", "fontSize": 12 }
                        },
                        {
                            "id": "btn_feat_1",
                            "type": "Button",
                            "text": "推荐商品 1",
                            "size": [358, 48],
                            "events": { "onClick": "@homeFeat1" },
                            "style": {
                                "bgColor": "#1A2030",
                                "color": "#F2F4F8",
                                "fontSize": 14,
                                "borderRadius": 12,
                                "borderColor": "#2E3648",
                                "borderWidth": 1
                            }
                        },
                        {
                            "id": "btn_feat_2",
                            "type": "Button",
                            "text": "推荐商品 2",
                            "size": [358, 48],
                            "events": { "onClick": "@homeFeat2" },
                            "style": {
                                "bgColor": "#1A2030",
                                "color": "#F2F4F8",
                                "fontSize": 14,
                                "borderRadius": 12,
                                "borderColor": "#2E3648",
                                "borderWidth": 1
                            }
                        },
                        {
                            "id": "btn_feat_3",
                            "type": "Button",
                            "text": "推荐商品 3",
                            "size": [358, 48],
                            "events": { "onClick": "@homeFeat3" },
                            "style": {
                                "bgColor": "#1A2030",
                                "color": "#F2F4F8",
                                "fontSize": 14,
                                "borderRadius": 12,
                                "borderColor": "#2E3648",
                                "borderWidth": 1
                            }
                        },
                        {
                            "id": "btn_feat_4",
                            "type": "Button",
                            "text": "推荐商品 4",
                            "size": [358, 48],
                            "events": { "onClick": "@homeFeat4" },
                            "style": {
                                "bgColor": "#1A2030",
                                "color": "#F2F4F8",
                                "fontSize": 14,
                                "borderRadius": 12,
                                "borderColor": "#2E3648",
                                "borderWidth": 1
                            }
                        }
                    ]
                },
                {
                    "id": "page_category",
                    "type": "View",
                    "flex": 1,
                    "visible": false,
                    "scrollable": 1,
                    "style": { "bgColor": "#0A0D12" },
                    "layout": { "type": "vertical", "spacing": 10, "padding": [12, 16, 16, 16] },
                    "events": { "onLoad": "@onCategoryLoad", "onShow": "@onCategoryShow" },
                    "children": [
                        {
                            "id": "category_header",
                            "type": "View",
                            "size": [358, 68],
                            "style": {
                                "bgColor": "#1A2030",
                                "borderRadius": 16,
                                "borderColor": "#2E3648",
                                "borderWidth": 1
                            },
                            "layout": { "type": "vertical", "spacing": 4, "padding": [14, 16, 14, 16] },
                            "children": [
                                {
                                    "id": "category_title",
                                    "type": "Label",
                                    "text": "分类",
                                    "style": { "color": "#FFFFFF", "fontSize": 20, "fontWeight": "bold" }
                                },
                                {
                                    "id": "category_hint",
                                    "type": "Label",
                                    "text": "请选择商品",
                                    "style": { "color": "#9AA3B2", "fontSize": 12 }
                                }
                            ]
                        },
                        {
                            "id": "btn_cat_item_1",
                            "type": "Button",
                            "text": "商品 1",
                            "size": [358, 52],
                            "events": { "onClick": "@categoryItem1" },
                            "style": {
                                "bgColor": "#1A2030",
                                "color": "#F2F4F8",
                                "fontSize": 14,
                                "borderRadius": 12,
                                "borderColor": "#2E3648",
                                "borderWidth": 1
                            }
                        },
                        {
                            "id": "btn_cat_item_2",
                            "type": "Button",
                            "text": "商品 2",
                            "size": [358, 52],
                            "events": { "onClick": "@categoryItem2" },
                            "style": {
                                "bgColor": "#1A2030",
                                "color": "#F2F4F8",
                                "fontSize": 14,
                                "borderRadius": 12,
                                "borderColor": "#2E3648",
                                "borderWidth": 1
                            }
                        },
                        {
                            "id": "btn_cat_item_3",
                            "type": "Button",
                            "text": "商品 3",
                            "size": [358, 52],
                            "events": { "onClick": "@categoryItem3" },
                            "style": {
                                "bgColor": "#1A2030",
                                "color": "#F2F4F8",
                                "fontSize": 14,
                                "borderRadius": 12,
                                "borderColor": "#2E3648",
                                "borderWidth": 1
                            }
                        }
                    ]
                },
                {
                    "id": "page_cart",
                    "type": "View",
                    "flex": 1,
                    "visible": false,
                    "style": { "bgColor": "#0A0D12" },
                    "layout": { "type": "vertical", "spacing": 10, "padding": [12, 16, 16, 16] },
                    "events": { "onLoad": "@onCartLoad", "onShow": "@onCartShow" },
                    "children": [
                        {
                            "id": "cart_header",
                            "type": "View",
                            "size": [358, 64],
                            "style": {
                                "bgColor": "#1A2030",
                                "borderRadius": 16,
                                "borderColor": "#2E3648",
                                "borderWidth": 1
                            },
                            "layout": { "type": "vertical", "spacing": 4, "padding": [14, 16, 14, 16] },
                            "children": [
                                {
                                    "id": "cart_title",
                                    "type": "Label",
                                    "text": "购物袋",
                                    "style": { "color": "#FFFFFF", "fontSize": 20, "fontWeight": "bold" }
                                },
                                {
                                    "id": "cart_user",
                                    "type": "Label",
                                    "text": "当前用户：-",
                                    "style": { "color": "#9AA3B2", "fontSize": 12 }
                                }
                            ]
                        },
                        {
                            "id": "cart_items_card",
                            "type": "View",
                            "flex": 1,
                            "style": {
                                "bgColor": "#12161E",
                                "borderRadius": 16,
                                "borderColor": "#2E3648",
                                "borderWidth": 1
                            },
                            "layout": { "type": "vertical", "spacing": 8, "padding": [14, 16, 14, 16] },
                            "children": [
                                {
                                    "id": "cart_line_1",
                                    "type": "Label",
                                    "text": "购物袋是空的",
                                    "style": { "color": "#9AA3B2", "fontSize": 14 }
                                },
                                {
                                    "id": "cart_line_2",
                                    "type": "Label",
                                    "text": "",
                                    "style": { "color": "#F2F4F8", "fontSize": 14 }
                                },
                                {
                                    "id": "cart_line_3",
                                    "type": "Label",
                                    "text": "",
                                    "style": { "color": "#F2F4F8", "fontSize": 14 }
                                }
                            ]
                        },
                        {
                            "id": "cart_total_bar",
                            "type": "View",
                            "size": [358, 48],
                            "style": {
                                "bgColor": "#1E2433",
                                "borderRadius": 12,
                                "borderColor": "#7C6CFF",
                                "borderWidth": 1
                            },
                            "layout": { "type": "vertical", "padding": [12, 16, 12, 16] },
                            "children": [
                                {
                                    "id": "cart_total",
                                    "type": "Label",
                                    "text": "合计  ¥0",
                                    "style": { "color": "#E8C47C", "fontSize": 17, "fontWeight": "bold" }
                                }
                            ]
                        },
                        {
                            "id": "cart_actions",
                            "type": "View",
                            "size": [358, 44],
                            "style": { "bgColor": "#0A0D12" },
                            "layout": { "type": "horizontal", "spacing": 10 },
                            "children": [
                                {
                                    "id": "btn_cart_clear",
                                    "type": "Button",
                                    "text": "清空",
                                    "flex": 1,
                                    "size": [0, 42],
                                    "events": { "onClick": "@cartClear" },
                                    "style": {
                                        "bgColor": "#1A2030",
                                        "color": "#EF5B5B",
                                        "fontSize": 14,
                                        "borderRadius": 10,
                                        "borderColor": "#2E3648",
                                        "borderWidth": 1
                                    }
                                },
                                {
                                    "id": "btn_cart_continue",
                                    "type": "Button",
                                    "text": "继续逛逛",
                                    "flex": 2,
                                    "size": [0, 42],
                                    "events": { "onClick": "@cartContinue" },
                                    "style": {
                                        "bgColor": "#7C6CFF",
                                        "color": "#FFFFFF",
                                        "fontSize": 14,
                                        "fontWeight": "bold",
                                        "borderRadius": 10
                                    }
                                }
                            ]
                        }
                    ]
                },
                {
                    "id": "page_login",
                    "type": "View",
                    "flex": 1,
                    "visible": false,
                    "style": { "bgColor": "#0A0D12" },
                    "layout": { "type": "vertical", "spacing": 0, "padding": [24, 16, 24, 16] },
                    "events": { "onLoad": "@onLoginLoad", "onShow": "@onLoginShow" },
                    "children": [
                        {
                            "id": "login_card",
                            "type": "View",
                            "size": [358, 340],
                            "style": {
                                "bgColor": "#1A2030",
                                "borderRadius": 20,
                                "borderColor": "#2E3648",
                                "borderWidth": 1
                            },
                            "layout": { "type": "vertical", "spacing": 12, "padding": [28, 24, 28, 24] },
                            "children": [
                                {
                                    "id": "login_title",
                                    "type": "Label",
                                    "text": "欢迎回来",
                                    "style": { "color": "#FFFFFF", "fontSize": 24, "fontWeight": "bold" }
                                },
                                {
                                    "id": "login_hint",
                                    "type": "Label",
                                    "text": "登录后即可查看购物袋并安全结算",
                                    "style": { "color": "#9AA3B2", "fontSize": 13 }
                                },
                                {
                                    "id": "login_redirect",
                                    "type": "Label",
                                    "text": "",
                                    "style": { "color": "#7C6CFF", "fontSize": 12 }
                                },
                                {
                                    "id": "btn_login_user",
                                    "type": "Button",
                                    "text": "普通用户登录（小明）",
                                    "size": [310, 46],
                                    "events": { "onClick": "@loginAsUser" },
                                    "style": {
                                        "bgColor": "#7C6CFF",
                                        "color": "#FFFFFF",
                                        "fontSize": 14,
                                        "fontWeight": "bold",
                                        "borderRadius": 12
                                    }
                                },
                                {
                                    "id": "btn_login_admin",
                                    "type": "Button",
                                    "text": "管理员登录（小红）",
                                    "size": [310, 46],
                                    "events": { "onClick": "@loginAsAdmin" },
                                    "style": {
                                        "bgColor": "#1E2433",
                                        "color": "#F2F4F8",
                                        "fontSize": 14,
                                        "borderRadius": 12,
                                        "borderColor": "#2E3648",
                                        "borderWidth": 1
                                    }
                                },
                                {
                                    "id": "btn_login_cancel",
                                    "type": "Button",
                                    "text": "稍后再说",
                                    "size": [310, 42],
                                    "events": { "onClick": "@loginCancel" },
                                    "style": {
                                        "bgColor": "#12161E",
                                        "color": "#6B7280",
                                        "fontSize": 13,
                                        "borderRadius": 10
                                    }
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "id": "status_bar",
            "type": "View",
            "size": [390, 24],
            "style": {
                "bgColor": "#12161E",
                "borderColor": "#252B3A",
                "borderWidth": 1
            },
            "layout": { "type": "vertical", "padding": [4, 14, 4, 14] },
            "children": [
                {
                    "id": "status_text",
                    "type": "Label",
                    "text": "首页",
                    "style": { "color": "#6B7280", "fontSize": 10 }
                }
            ]
        }
    ]
}
